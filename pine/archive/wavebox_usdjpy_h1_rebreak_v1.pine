//@version=5
strategy("WaveBox USDJPY H1 Rebreak v1.1 Practical",
     overlay=true,
     pyramiding=0,
     max_bars_back=5000,
     max_lines_count=500,
     max_labels_count=500,
     max_boxes_count=100,
     calc_on_order_fills=true,
     calc_on_every_tick=true,
     currency=currency.JPY,
     initial_capital=1000000,
     default_qty_type=strategy.fixed,
     default_qty_value=1)

// WaveBox USDJPY H1 Rebreak v1.1 Practical
// Python検証の実戦標準条件:
// USDJPY / H1 / box 8 / box幅 2.0ATR以内 / TP 1.5R
// 標準: 1波剪定ON / 2波戻し 50%-78.6% / entry hour 1,6,14除外 / 年末年始除外
// 保守: 2波戻し 50%-76.4% / entry hour 1,6,11,14除外 / 年末年始除外
//
// 注意:
// - 検証CSVの時刻はブローカー時刻。TradingViewでは「除外時間タイムゾーン」を必ず合わせる。
// - strategy注文はTradingViewの約定仕様に従うため、実力評価は内部R集計を優先する。
// - 実運用確認用のため、request.securityのlookahead_onは使わない。

//------------------------------------------------------------------------------
// Inputs
//------------------------------------------------------------------------------
grpCore = "v1 Core"
enforceUsdJpy = input.bool(true, "USDJPY以外はシグナル停止", group=grpCore)
enforceH1 = input.bool(true, "H1以外はシグナル停止", group=grpCore)
rulePreset = input.string("v0.4 filtered", "ルールプリセット", options=["v0.4 filtered", "v0.3 strict", "v0.4 less-fit", "Custom"], group=grpCore)
atrLen = input.int(14, "ATR", minval=1, group=grpCore)
pivotWidth = input.int(3, "Pivot幅", minval=1, maxval=20, group=grpCore)
minSwingAtr = input.float(1.15, "Pivot間の最小スイング ATR倍", minval=0.1, step=0.05, group=grpCore)
minWave1Atr = input.float(1.60, "1波の最小値幅 ATR倍", minval=0.1, step=0.05, group=grpCore)
retraceMin = input.float(0.500, "2波戻し 下限", minval=0.0, maxval=2.0, step=0.001, group=grpCore)
customRetraceMax = input.float(0.764, "Custom 2波戻し 上限", minval=0.0, maxval=2.0, step=0.001, group=grpCore)
minAdjustRatio = input.float(0.30, "2波の最低時間比", minval=0.0, step=0.05, group=grpCore)
maxRecovery = input.float(0.92, "ブレイク時の最大回復率", minval=0.1, maxval=2.0, step=0.01, group=grpCore)
minBodyRatio = input.float(0.25, "ブレイク足の最小実体率", minval=0.0, maxval=1.0, step=0.05, group=grpCore)

grpWave1 = "Wave1 Quality"
useWave1Quality = input.bool(true, "1波剪定を使う", group=grpWave1)
wave1QualityPreset = input.string("Strict", "1波剪定プリセット", options=["Strict", "Balanced", "Loose", "Custom"], group=grpWave1)
customQualityMinWave1Atr = input.float(3.0, "Custom 1波の最低値幅 ATR倍", minval=0.1, step=0.1, group=grpWave1)
customQualityMinWave1Speed = input.float(0.35, "Custom 1波の最低速度 ATR/本", minval=0.0, step=0.05, group=grpWave1)
customQualityMaxWave1Bars = input.int(24, "Custom 1波の最大本数", minval=1, maxval=100, group=grpWave1)
useWave1RangeBreak = input.bool(false, "1波のレンジ抜け確認（研究）", group=grpWave1)
rangeBreakLookback = input.int(24, "レンジ抜け確認の過去本数", minval=5, maxval=100, group=grpWave1)

grpBox = "Box / Break"
boxBars = input.int(8, "Box本数", minval=2, maxval=30, group=grpBox)
boxAtrMax = input.float(2.0, "Box幅 上限 ATR倍", minval=0.1, step=0.1, group=grpBox)
breakBufferAtr = input.float(0.05, "ブレイク余白 ATR倍", minval=0.0, step=0.01, group=grpBox)
maxChaseAtr = input.float(0.80, "ブレイク追いかけ上限 ATR倍", minval=0.0, step=0.05, group=grpBox)
maxSetupAge = input.int(36, "P2確定後の有効期限 本", minval=1, maxval=200, group=grpBox)

grpTrend = "Trend / Rank"
emaLen = input.int(20, "EMA", minval=1, group=grpTrend)
emaSlopeBars = input.int(3, "EMA傾き確認 本", minval=1, maxval=20, group=grpTrend)
useH4AsFilter = input.bool(false, "H4逆行なしを必須にする", group=grpTrend)
aPlusRetraceMax = input.float(0.618, "A+戻し上限", minval=0.0, maxval=1.0, step=0.001, group=grpTrend)

grpRisk = "Risk / Time"
rr = input.float(1.5, "TP R倍", minval=0.1, step=0.1, group=grpRisk)
stopBufferAtr = input.float(0.20, "SL余白 ATR倍", minval=0.0, step=0.05, group=grpRisk)
maxHoldBars = input.int(72, "最大保有本数", minval=1, maxval=300, group=grpRisk)
brokerTz = input.string("UTC", "除外時間タイムゾーン", group=grpRisk)
useHourFilter = input.bool(true, "entry hour除外を使う", group=grpRisk)
customExcludeHour1 = input.bool(true, "Custom 除外 1時", group=grpRisk)
customExcludeHour6 = input.bool(true, "Custom 除外 6時", group=grpRisk)
customExcludeHour11 = input.bool(true, "Custom 除外 11時", group=grpRisk)
customExcludeHour14 = input.bool(true, "Custom 除外 14時", group=grpRisk)
useHolidayFilter = input.bool(true, "12/15以降と1/10以前を除外", group=grpRisk)
spreadPrice = input.float(0.010, "内部R集計 spread price", minval=0.0, step=0.001, group=grpRisk)
slipPrice = input.float(0.005, "内部R集計 slip price", minval=0.0, step=0.001, group=grpRisk)

grpOrders = "Strategy Orders"
enableOrders = input.bool(false, "参考strategy注文を出す", group=grpOrders)
orderMinRank = input.string("A", "注文対象の最低ランク", options=["B", "A", "A+"], group=grpOrders)
orderSizingMode = input.string("Risk %", "注文数量方式", options=["Risk %", "Fixed qty"], group=grpOrders)
accountSizeJpy = input.float(1000000, "想定資金 JPY", minval=10000, step=10000, group=grpOrders)
riskPct = input.float(0.25, "1回の許容リスク %", minval=0.01, maxval=10.0, step=0.01, group=grpOrders)
fixedQty = input.float(1000, "固定数量", minval=1, step=1000, group=grpOrders)
maxQty = input.float(100000, "最大数量", minval=1, step=1000, group=grpOrders)

grpView = "Visual"
showPivots = input.bool(false, "Pivot表示", group=grpView)
showBox = input.bool(true, "Box上下限表示", group=grpView)
showSignalLabels = input.bool(true, "SIGNAL表示", group=grpView)
showBSignals = input.bool(true, "Bシグナルを小さく表示", group=grpView)
largeSignalMinRank = input.string("A", "詳細ラベルの最低ランク", options=["B", "A", "A+"], group=grpView)
showEntryExitMarks = input.bool(true, "ENTRY/EXITマーカー表示", group=grpView)
showEntryExitText = input.bool(false, "ENTRY/EXIT文字ラベル表示", group=grpView)
showTradeLines = input.bool(true, "Entry/SL/TPライン表示", group=grpView)
showTable = input.bool(true, "内部R集計テーブル表示", group=grpView)
tablePosInput = input.string("bottom_left", "テーブル位置", options=["top_right", "top_left", "bottom_right", "bottom_left"], group=grpView)
labelAtrAway = input.float(2.2, "詳細ラベル上下余白 ATR倍", minval=0.1, step=0.1, group=grpView)

//------------------------------------------------------------------------------
// Core series
//------------------------------------------------------------------------------
atrValue = ta.atr(atrLen)
emaValue = ta.ema(close, emaLen)
emaSlope = emaValue - emaValue[emaSlopeBars]
barRange = high - low
bodyRatio = barRange > 0 ? math.abs(close - open) / barRange : 0.0
boxHigh = ta.highest(high[1], boxBars)
boxLow = ta.lowest(low[1], boxBars)
boxWidth = boxHigh - boxLow
breakBuffer = atrValue * breakBufferAtr
qualityMinWave1Atr = wave1QualityPreset == "Balanced" ? 2.7 : wave1QualityPreset == "Loose" ? 2.5 : wave1QualityPreset == "Custom" ? customQualityMinWave1Atr : 3.0
qualityMinWave1Speed = wave1QualityPreset == "Balanced" ? 0.32 : wave1QualityPreset == "Loose" ? 0.30 : wave1QualityPreset == "Custom" ? customQualityMinWave1Speed : 0.35
qualityMaxWave1Bars = wave1QualityPreset == "Balanced" ? 28 : wave1QualityPreset == "Loose" ? 30 : wave1QualityPreset == "Custom" ? customQualityMaxWave1Bars : 24

isH1Chart = timeframe.in_seconds(timeframe.period) == 3600
isUsdJpy = str.contains(syminfo.ticker, "USDJPY") or str.contains(syminfo.tickerid, "USDJPY")
envOk = (not enforceUsdJpy or isUsdJpy) and (not enforceH1 or isH1Chart)

retraceMaxEff = rulePreset == "v0.4 filtered" or rulePreset == "v0.4 less-fit" ? 0.786 : rulePreset == "v0.3 strict" ? 0.764 : customRetraceMax
excludeHour1 = rulePreset == "Custom" ? customExcludeHour1 : true
excludeHour6 = rulePreset == "Custom" ? customExcludeHour6 : true
excludeHour11 = rulePreset == "v0.3 strict" ? true : rulePreset == "Custom" ? customExcludeHour11 : false
excludeHour14 = rulePreset == "v0.3 strict" or rulePreset == "v0.4 filtered" ? true : rulePreset == "Custom" ? customExcludeHour14 : false

entryHour = hour(time_close, brokerTz)
entryMonth = month(time_close, brokerTz)
entryDay = dayofmonth(time_close, brokerTz)
isExcludedHour = useHourFilter and ((excludeHour1 and entryHour == 1) or (excludeHour6 and entryHour == 6) or (excludeHour11 and entryHour == 11) or (excludeHour14 and entryHour == 14))
isHoliday = useHolidayFilter and ((entryMonth == 12 and entryDay >= 15) or (entryMonth == 1 and entryDay <= 10))
timeOk = not isExcludedHour and not isHoliday

h4Close = request.security(syminfo.tickerid, "240", close, barmerge.gaps_off, barmerge.lookahead_off)
h4Ema = request.security(syminfo.tickerid, "240", ta.ema(close, 100), barmerge.gaps_off, barmerge.lookahead_off)
h4Slope = request.security(syminfo.tickerid, "240", ta.ema(close, 100) - ta.ema(close, 100)[6], barmerge.gaps_off, barmerge.lookahead_off)

//------------------------------------------------------------------------------
// Pivot store
//------------------------------------------------------------------------------
var int[] pBars = array.new_int()
var int[] pConfirmBars = array.new_int()
var float[] pPrices = array.new_float()
var float[] pAtrs = array.new_float()
var int[] pKinds = array.new_int()  // 1 = high, -1 = low

f_trim_pivots(array<int> bars, array<int> confirmBars, array<float> prices, array<float> atrs, array<int> kinds) =>
    int maxPivots = 120
    while array.size(bars) > maxPivots
        array.shift(bars)
        array.shift(confirmBars)
        array.shift(prices)
        array.shift(atrs)
        array.shift(kinds)

f_add_pivot(array<int> bars, array<int> confirmBars, array<float> prices, array<float> atrs, array<int> kinds, int pBar, int pConfirmBar, float pPrice, float pAtr, int pKind) =>
    bool accepted = false
    int n = array.size(bars)
    if n == 0
        array.push(bars, pBar)
        array.push(confirmBars, pConfirmBar)
        array.push(prices, pPrice)
        array.push(atrs, pAtr)
        array.push(kinds, pKind)
        accepted := true
    else
        int lastKind = array.get(kinds, n - 1)
        float lastPrice = array.get(prices, n - 1)
        float lastAtr = array.get(atrs, n - 1)
        if pKind == lastKind
            bool moreExtreme = (pKind == 1 and pPrice > lastPrice) or (pKind == -1 and pPrice < lastPrice)
            if moreExtreme
                array.set(bars, n - 1, pBar)
                array.set(confirmBars, n - 1, pConfirmBar)
                array.set(prices, n - 1, pPrice)
                array.set(atrs, n - 1, pAtr)
                accepted := true
        else
            float swing = math.abs(pPrice - lastPrice)
            float threshold = math.max(pAtr, lastAtr) * minSwingAtr
            if swing >= threshold
                array.push(bars, pBar)
                array.push(confirmBars, pConfirmBar)
                array.push(prices, pPrice)
                array.push(atrs, pAtr)
                array.push(kinds, pKind)
                accepted := true
    f_trim_pivots(bars, confirmBars, prices, atrs, kinds)
    accepted

f_wave1_breaks_prior_range(int p0BarIn, int dir, float p1PriceIn, int lookback, float buffer) =>
    bool ok = false
    int p0Offset = bar_index - p0BarIn
    bool enoughHistory = p0Offset >= 0 and bar_index >= p0Offset + lookback
    if enoughHistory
        float priorHigh = na
        float priorLow = na
        for k = 1 to lookback
            int off = p0Offset + k
            priorHigh := na(priorHigh) ? high[off] : math.max(priorHigh, high[off])
            priorLow := na(priorLow) ? low[off] : math.min(priorLow, low[off])
        ok := dir == 1 ? p1PriceIn > priorHigh + buffer : p1PriceIn < priorLow - buffer
    ok

pivotWindow = pivotWidth * 2 + 1
canCheckPivot = bar_index >= pivotWidth * 2 and not na(atrValue[pivotWidth])
isRawHighPivot = canCheckPivot and high[pivotWidth] >= ta.highest(high, pivotWindow)
isRawLowPivot = canCheckPivot and low[pivotWidth] <= ta.lowest(low, pivotWindow)
isHighPivot = isRawHighPivot and not isRawLowPivot
isLowPivot = isRawLowPivot and not isRawHighPivot

bool acceptedHighPivot = false
bool acceptedLowPivot = false
if isHighPivot
    acceptedHighPivot := f_add_pivot(pBars, pConfirmBars, pPrices, pAtrs, pKinds, bar_index - pivotWidth, bar_index, high[pivotWidth], atrValue[pivotWidth], 1)
if isLowPivot
    acceptedLowPivot := f_add_pivot(pBars, pConfirmBars, pPrices, pAtrs, pKinds, bar_index - pivotWidth, bar_index, low[pivotWidth], atrValue[pivotWidth], -1)

plotshape(showPivots and acceptedHighPivot, title="Accepted Pivot H Confirmed", style=shape.circle, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny)
plotshape(showPivots and acceptedLowPivot, title="Accepted Pivot L Confirmed", style=shape.circle, location=location.belowbar, color=color.new(color.lime, 0), size=size.tiny)

plot(showBox ? boxHigh : na, title="WaveBox High", color=color.new(color.orange, 15), linewidth=1, style=plot.style_linebr)
plot(showBox ? boxLow : na, title="WaveBox Low", color=color.new(color.teal, 15), linewidth=1, style=plot.style_linebr)
plot(emaValue, title="EMA20", color=color.new(color.white, 25))

//------------------------------------------------------------------------------
// Signal calculation
//------------------------------------------------------------------------------
int nPivots = array.size(pBars)
bool hasWave = nPivots >= 3

int p0Bar = hasWave ? array.get(pBars, nPivots - 3) : na
int p1Bar = hasWave ? array.get(pBars, nPivots - 2) : na
int p2Bar = hasWave ? array.get(pBars, nPivots - 1) : na
int p2ConfirmBar = hasWave ? array.get(pConfirmBars, nPivots - 1) : na
int p0Kind = hasWave ? array.get(pKinds, nPivots - 3) : 0
int p1Kind = hasWave ? array.get(pKinds, nPivots - 2) : 0
int p2Kind = hasWave ? array.get(pKinds, nPivots - 1) : 0
float p0Price = hasWave ? array.get(pPrices, nPivots - 3) : na
float p1Price = hasWave ? array.get(pPrices, nPivots - 2) : na
float p2Price = hasWave ? array.get(pPrices, nPivots - 1) : na

bool longSeq = hasWave and p0Kind == -1 and p1Kind == 1 and p2Kind == -1
bool shortSeq = hasWave and p0Kind == 1 and p1Kind == -1 and p2Kind == 1
int setupAge = hasWave ? bar_index - p2ConfirmBar : na
bool setupAgeOk = hasWave and setupAge >= 0 and setupAge <= maxSetupAge
bool boxOk = not na(boxHigh) and not na(boxLow) and boxWidth > 0 and boxWidth <= atrValue * boxAtrMax

float wave1 = na
float retrace = na
float recovery = na
float chaseAtr = na
float stopPrice = na
float adjustRatio = na
bool breakout = false
bool emaOk = false
int direction = 0

if longSeq and setupAgeOk and boxOk and not na(close[1])
    direction := 1
    wave1 := p1Price - p0Price
    bool waveShapeOk = wave1 > atrValue * minWave1Atr and p2Price > p0Price + breakBuffer
    if waveShapeOk
        retrace := (p1Price - p2Price) / wave1
        recovery := (close - p2Price) / math.max(p1Price - p2Price, atrValue * 0.01)
        breakout := close > boxHigh + breakBuffer and close[1] <= boxHigh + breakBuffer
        emaOk := close > emaValue and emaSlope > 0
        chaseAtr := (close - boxHigh) / atrValue
        stopPrice := math.min(p2Price, boxLow) - atrValue * stopBufferAtr

if shortSeq and setupAgeOk and boxOk and not na(close[1])
    direction := -1
    wave1 := p0Price - p1Price
    bool waveShapeOk = wave1 > atrValue * minWave1Atr and p2Price < p0Price - breakBuffer
    if waveShapeOk
        retrace := (p2Price - p1Price) / wave1
        recovery := (p2Price - close) / math.max(p2Price - p1Price, atrValue * 0.01)
        breakout := close < boxLow - breakBuffer and close[1] >= boxLow - breakBuffer
        emaOk := close < emaValue and emaSlope < 0
        chaseAtr := (boxLow - close) / atrValue
        stopPrice := math.max(p2Price, boxHigh) + atrValue * stopBufferAtr

float wave1Bars = hasWave ? math.max(p1Bar - p0Bar, 1) : na
float adjustBars = hasWave ? math.max(p2Bar - p1Bar, 1) : na
adjustRatio := hasWave ? adjustBars / wave1Bars : na
float wave1AtrRatio = not na(wave1) and atrValue > 0 ? wave1 / atrValue : na
float wave1Speed = not na(wave1AtrRatio) and wave1Bars > 0 ? wave1AtrRatio / wave1Bars : na
bool wave1RangeBreakOk = not useWave1RangeBreak or (hasWave and direction != 0 and f_wave1_breaks_prior_range(p0Bar, direction, p1Price, rangeBreakLookback, breakBuffer))
bool wave1QualityOk = not useWave1Quality or (not na(wave1AtrRatio) and not na(wave1Speed) and wave1AtrRatio >= qualityMinWave1Atr and wave1Speed >= qualityMinWave1Speed and wave1Bars <= qualityMaxWave1Bars and wave1RangeBreakOk)

bool retraceOk = not na(retrace) and retrace >= retraceMin and retrace <= retraceMaxEff
bool adjustOk = not na(adjustRatio) and adjustRatio >= minAdjustRatio
bool recoveryOk = not na(recovery) and recovery <= maxRecovery
bool bodyOk = bodyRatio >= minBodyRatio
bool chaseOk = not na(chaseAtr) and chaseAtr >= 0 and chaseAtr <= maxChaseAtr

bool h4OpposeLong = h4Close < h4Ema and h4Slope < 0
bool h4OpposeShort = h4Close > h4Ema and h4Slope > 0
bool h4Oppose = direction == 1 ? h4OpposeLong : direction == -1 ? h4OpposeShort : false
bool h4NotOppose = not h4Oppose
bool h4FilterOk = not useH4AsFilter or h4NotOppose

bool rawCoreSignal = envOk and timeOk and h4FilterOk and breakout and retraceOk and adjustOk and recoveryOk and bodyOk and emaOk and chaseOk and wave1QualityOk and not na(stopPrice)
string setupKey = hasWave ? str.tostring(direction) + ":" + str.tostring(p0Bar) + "-" + str.tostring(p1Bar) + "-" + str.tostring(p2Bar) : ""

bool aPlus = rawCoreSignal and retrace <= aPlusRetraceMax
bool aGrade = rawCoreSignal and h4NotOppose and not aPlus
int rankScore = aPlus ? 2 : aGrade ? 1 : rawCoreSignal ? 0 : -1
string gradeText = aPlus ? "A+" : aGrade ? "A" : rawCoreSignal ? "B" : "NONE"
float boxMid = (boxHigh + boxLow) / 2.0
float wave2Range = direction == 1 ? p1Price - p2Price : direction == -1 ? p2Price - p1Price : na
float boxMidRecovery = not na(wave2Range) and wave2Range > 0 ? (direction == 1 ? (boxMid - p2Price) / wave2Range : (p2Price - boxMid) / wave2Range) : na
float closeLocation = barRange > 0 ? (direction == 1 ? (close - low) / barRange : direction == -1 ? (high - close) / barRange : na) : na
bool breakStrongClose = rawCoreSignal and bodyRatio >= 0.65 and closeLocation >= 0.70
bool breakOkClose = rawCoreSignal and bodyRatio >= 0.45 and closeLocation >= 0.60
bool boxNotLate = rawCoreSignal and not na(boxMidRecovery) and boxMidRecovery <= 0.65
bool earlyOrNormal = rawCoreSignal and ((recovery <= 0.65 and chaseAtr <= 0.40) or (recovery <= 0.80 and chaseAtr <= 0.60))
bool strictMode = useWave1Quality and wave1QualityPreset == "Strict" and rulePreset == "v0.4 filtered"
bool cleanA = aGrade and boxNotLate and (breakStrongClose or breakOkClose) and earlyOrNormal
string actionText = aPlus ? "GO A+" : cleanA ? "GO A" : aGrade ? "SELECT A" : rawCoreSignal and rankScore == 0 and strictMode ? "OBS B" : rawCoreSignal ? "SKIP" : "WAIT"
int orderMinRankScore = orderMinRank == "A+" ? 2 : orderMinRank == "A" ? 1 : 0
bool orderRankOk = rankScore >= orderMinRankScore
int largeSignalMinRankScore = largeSignalMinRank == "A+" ? 2 : largeSignalMinRank == "A" ? 1 : 0
bool largeSignalOk = rankScore >= largeSignalMinRankScore

//------------------------------------------------------------------------------
// Python-like internal R simulation
//------------------------------------------------------------------------------
var bool simPending = false
var int pendingDir = 0
var int pendingSignalBar = na
var float pendingStop = na
var int pendingRankScore = na

var bool simInTrade = false
var int simDir = 0
var int simEntryBar = na
var int simRankScore = na
var float simEntry = na
var float simStop = na
var float simTarget = na
var float simRisk = na

var string lastSetupKey = ""
var string lastSignalRank = "NONE"
var int simTrades = 0
var int simWins = 0
var float simTotalR = 0.0
var float simGrossProfit = 0.0
var float simGrossLoss = 0.0
var float simPeakR = 0.0
var float simMaxDdR = 0.0

bool simEnteredThisBar = false
bool simExitedThisBar = false
int simEntryDir = 0
float simExitPrice = na
float simExitR = na
string simExitReason = ""

if simPending and bar_index > pendingSignalBar
    float entry = open
    float risk = pendingDir == 1 ? entry - pendingStop : pendingStop - entry
    if risk > 0
        simInTrade := true
        simEnteredThisBar := true
        simEntryDir := pendingDir
        simDir := pendingDir
        simEntryBar := bar_index
        simRankScore := pendingRankScore
        simEntry := entry
        simStop := pendingStop
        simRisk := risk
        simTarget := pendingDir == 1 ? entry + risk * rr : entry - risk * rr
        if showEntryExitText
            string entrySide = pendingDir == 1 ? "BUY" : "SELL"
            color entryColor = pendingDir == 1 ? color.new(color.lime, 0) : color.new(color.red, 0)
            label.new(bar_index, entry, "ENTRY " + entrySide + "\n" + str.tostring(entry, format.mintick), style=pendingDir == 1 ? label.style_label_up : label.style_label_down, color=entryColor, textcolor=color.white, size=size.small)
        if showTradeLines
            line.new(bar_index, entry, bar_index + maxHoldBars, entry, color=color.new(color.white, 30), style=line.style_dotted)
            line.new(bar_index, pendingStop, bar_index + maxHoldBars, pendingStop, color=color.new(color.red, 15), style=line.style_dashed)
            line.new(bar_index, simTarget, bar_index + maxHoldBars, simTarget, color=color.new(color.lime, 15), style=line.style_dashed)
    simPending := false
    pendingRankScore := na

if simInTrade
    int heldBars = bar_index - simEntryBar
    bool hitSl = simDir == 1 ? low <= simStop : high >= simStop
    bool hitTp = simDir == 1 ? high >= simTarget : low <= simTarget
    if hitSl or hitTp
        simExitPrice := hitSl ? simStop : simTarget
        simExitReason := hitSl and hitTp ? "SL_first_same_bar" : hitSl ? "SL" : "TP"
        simExitedThisBar := true
    else if heldBars >= maxHoldBars
        simExitPrice := close
        simExitReason := "TIME"
        simExitedThisBar := true

    if simExitedThisBar
        float costR = simDir == 1 ? ((simExitPrice - slipPrice) - (simEntry + spreadPrice / 2.0)) / simRisk : ((simEntry - spreadPrice / 2.0) - (simExitPrice + slipPrice)) / simRisk
        simExitR := costR
        simTrades += 1
        simWins += costR > 0 ? 1 : 0
        simTotalR += costR
        simGrossProfit += costR > 0 ? costR : 0.0
        simGrossLoss += costR <= 0 ? costR : 0.0
        simPeakR := math.max(simPeakR, simTotalR)
        simMaxDdR := math.max(simMaxDdR, simPeakR - simTotalR)
        color exitColor = costR > 0 ? color.new(color.lime, 0) : color.new(color.red, 0)
        if showEntryExitText
            label.new(bar_index, simExitPrice, "EXIT " + simExitReason + "\n" + str.tostring(costR, "#.##") + "R", style=label.style_label_left, color=exitColor, textcolor=color.white, size=size.tiny)
        simInTrade := false
        simDir := 0
        simEntryBar := na
        simRankScore := na
        simEntry := na
        simStop := na
        simTarget := na
        simRisk := na

bool canArmSignal = barstate.isconfirmed and rawCoreSignal and not simInTrade and not simPending and not simExitedThisBar and setupKey != lastSetupKey
if canArmSignal
    simPending := true
    pendingDir := direction
    pendingSignalBar := bar_index
    pendingStop := stopPrice
    pendingRankScore := rankScore
    lastSetupKey := setupKey
    lastSignalRank := gradeText

//------------------------------------------------------------------------------
// Strategy orders and visuals
//------------------------------------------------------------------------------
var float strategyStop = na
if canArmSignal and enableOrders and orderRankOk
    strategyStop := stopPrice
    float strategyRiskDist = direction == 1 ? close - stopPrice : stopPrice - close
    float pointValue = syminfo.pointvalue > 0 ? syminfo.pointvalue : 1.0
    float riskCapital = accountSizeJpy * riskPct * 0.01
    float riskQty = strategyRiskDist > 0 ? riskCapital / (strategyRiskDist * pointValue) : na
    float orderQty = orderSizingMode == "Risk %" ? math.min(riskQty, maxQty) : fixedQty
    if not na(orderQty) and orderQty > 0
        if direction == 1
            strategy.entry("L", strategy.long, qty=orderQty, comment=aPlus ? "A+ BUY" : aGrade ? "A BUY" : "B BUY")
        if direction == -1
            strategy.entry("S", strategy.short, qty=orderQty, comment=aPlus ? "A+ SELL" : aGrade ? "A SELL" : "B SELL")

if enableOrders and strategy.position_size > 0 and not na(strategyStop)
    float risk = strategy.position_avg_price - strategyStop
    if risk > 0
        strategy.exit("XL", "L", stop=strategyStop, limit=strategy.position_avg_price + risk * rr)

if enableOrders and strategy.position_size < 0 and not na(strategyStop)
    float risk = strategyStop - strategy.position_avg_price
    if risk > 0
        strategy.exit("XS", "S", stop=strategyStop, limit=strategy.position_avg_price - risk * rr)

if enableOrders and strategy.position_size != 0 and strategy.opentrades > 0
    int barsInStrategyTrade = bar_index - strategy.opentrades.entry_bar_index(0)
    if barsInStrategyTrade >= maxHoldBars
        strategy.close_all(comment="TIME")

if strategy.position_size == 0 and strategy.position_size[1] != 0
    strategyStop := na

color buyColor = aPlus ? color.new(color.lime, 0) : aGrade ? color.new(color.green, 0) : color.new(color.teal, 0)
color sellColor = aPlus ? color.new(color.fuchsia, 0) : aGrade ? color.new(color.red, 0) : color.new(color.orange, 0)

bool signalBuy = canArmSignal and direction == 1
bool signalSell = canArmSignal and direction == -1
bool entryBuy = simEnteredThisBar and simEntryDir == 1
bool entrySell = simEnteredThisBar and simEntryDir == -1
bool exitTp = simExitedThisBar and simExitReason == "TP"
bool exitSl = simExitedThisBar and (simExitReason == "SL" or simExitReason == "SL_first_same_bar")
bool exitTime = simExitedThisBar and simExitReason == "TIME"

plotshape(showSignalLabels and signalBuy and aPlus, title="WaveBox Signal Buy A+", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.normal, text="A+")
plotshape(showSignalLabels and signalSell and aPlus, title="WaveBox Signal Sell A+", style=shape.triangledown, location=location.abovebar, color=color.new(color.fuchsia, 0), size=size.normal, text="A+")
plotshape(showSignalLabels and signalBuy and aGrade, title="WaveBox Signal Buy A", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.small, text="A")
plotshape(showSignalLabels and signalSell and aGrade, title="WaveBox Signal Sell A", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="A")
plotshape(showSignalLabels and showBSignals and signalBuy and rankScore == 0, title="WaveBox Signal Buy B", style=shape.circle, location=location.belowbar, color=color.new(color.teal, 35), size=size.tiny, text="B")
plotshape(showSignalLabels and showBSignals and signalSell and rankScore == 0, title="WaveBox Signal Sell B", style=shape.circle, location=location.abovebar, color=color.new(color.orange, 35), size=size.tiny, text="B")
plotshape(showEntryExitMarks and entryBuy, title="WaveBox Entry Buy", style=shape.arrowup, location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="EN")
plotshape(showEntryExitMarks and entrySell, title="WaveBox Entry Sell", style=shape.arrowdown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="EN")
plotshape((showEntryExitMarks and exitTp) ? simExitPrice : na, title="WaveBox Exit TP", style=shape.diamond, location=location.absolute, color=color.new(color.lime, 0), size=size.tiny, text="TP")
plotshape((showEntryExitMarks and exitSl) ? simExitPrice : na, title="WaveBox Exit SL", style=shape.xcross, location=location.absolute, color=color.new(color.red, 0), size=size.tiny, text="SL")
plotshape((showEntryExitMarks and exitTime) ? simExitPrice : na, title="WaveBox Exit Time", style=shape.square, location=location.absolute, color=color.new(color.gray, 0), size=size.tiny, text="TM")

if canArmSignal and showSignalLabels and largeSignalOk and (rankScore > 0 or showBSignals)
    float y = direction == 1 ? low - atrValue * labelAtrAway : high + atrValue * labelAtrAway
    string sideText = direction == 1 ? "BUY" : "SELL"
    string info = "SIGNAL " + gradeText + " " + sideText +
         "\n" + actionText +
         "\nNext open entry" +
         "\nW1 " + str.tostring(wave1AtrRatio, "#.#") + "ATR / " + str.tostring(wave1Speed, "#.##") + "/bar" +
         "\nRet " + str.tostring(retrace * 100.0, "#.#") + "%" +
         "\nBox " + str.tostring(boxWidth / atrValue, "#.##") + "ATR" +
         "\nChase " + str.tostring(chaseAtr, "#.##") + "ATR" +
         "\nH4 " + (h4NotOppose ? "OK" : "逆行")
    label.new(bar_index, y, info, style=direction == 1 ? label.style_label_up : label.style_label_down, color=direction == 1 ? buyColor : sellColor, textcolor=color.white, size=rankScore == 2 ? size.normal : size.small)

alertcondition(signalBuy, title="WaveBox SIGNAL BUY", message="WaveBox signal BUY. Entry is next H1 open.")
alertcondition(signalSell, title="WaveBox SIGNAL SELL", message="WaveBox signal SELL. Entry is next H1 open.")
alertcondition(entryBuy, title="WaveBox ENTRY BUY", message="WaveBox ENTRY BUY at current H1 open.")
alertcondition(entrySell, title="WaveBox ENTRY SELL", message="WaveBox ENTRY SELL at current H1 open.")
alertcondition(exitTp, title="WaveBox EXIT TP", message="WaveBox EXIT TP.")
alertcondition(exitSl, title="WaveBox EXIT SL", message="WaveBox EXIT SL.")
alertcondition(exitTime, title="WaveBox EXIT TIME", message="WaveBox EXIT TIME.")
alertcondition(signalBuy or signalSell, title="WaveBox SIGNAL ANY", message="WaveBox signal. Entry is next H1 open.")
alertcondition(entryBuy or entrySell, title="WaveBox ENTRY ANY", message="WaveBox entry.")
alertcondition(simExitedThisBar, title="WaveBox EXIT ANY", message="WaveBox exit.")
alertcondition(canArmSignal and aGrade, title="WaveBox SIGNAL A", message="WaveBox A signal. Entry is next H1 open.")
alertcondition(canArmSignal and aPlus, title="WaveBox SIGNAL A+", message="WaveBox A+ signal. Entry is next H1 open.")
alertcondition(canArmSignal and cleanA, title="WaveBox SIGNAL CLEAN A", message="WaveBox clean A signal. Entry is next H1 open.")
alertcondition(canArmSignal and (aPlus or cleanA), title="WaveBox SIGNAL GO", message="WaveBox GO signal. Entry is next H1 open.")

//------------------------------------------------------------------------------
// Table
//------------------------------------------------------------------------------
f_pct(float x) =>
    str.tostring(x, "#.##") + "%"

f_num(float x) =>
    na(x) ? "N/A" : str.tostring(x, "#.##")

f_table_pos(string pos) =>
    pos == "top_left" ? position.top_left : pos == "bottom_right" ? position.bottom_right : pos == "bottom_left" ? position.bottom_left : position.top_right

f_rank_text(int score) =>
    score == 2 ? "A+" : score == 1 ? "A" : score == 0 ? "B" : "NONE"

var table t = table.new(f_table_pos(tablePosInput), 2, 22, border_width=1)
if showTable and barstate.islast
    float winRate = simTrades > 0 ? (simWins * 100.0) / simTrades : na
    float avgR = simTrades > 0 ? simTotalR / simTrades : na
    float pf = simGrossLoss < 0 ? simGrossProfit / math.abs(simGrossLoss) : na
    string envText = (isUsdJpy ? "USDJPY OK" : "Not USDJPY") + " / " + (isH1Chart ? "H1 OK" : "Not H1")
    color envColor = envOk ? color.new(color.green, 70) : color.new(color.red, 60)
    table.cell(t, 0, 0, "WaveBox v1.1", text_color=color.white, bgcolor=color.new(color.black, 0), text_size=size.small)
    table.cell(t, 1, 0, envText, text_color=color.white, bgcolor=envColor, text_size=size.small)
    table.cell(t, 0, 1, "評価基準", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 1, "内部R優先", text_color=color.lime, text_size=size.tiny)
    table.cell(t, 0, 2, "strategy", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, enableOrders ? "ON 参考" : "OFF 推奨", text_color=enableOrders ? color.yellow : color.lime, text_size=size.tiny)
    table.cell(t, 0, 3, "内部 trades", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, str.tostring(simTrades), text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 4, "勝率", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, na(winRate) ? "N/A" : f_pct(winRate), text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 5, "Total R", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(simTotalR, "#.##") + "R", text_color=simTotalR >= 0 ? color.lime : color.red, text_size=size.tiny)
    table.cell(t, 0, 6, "Avg R", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 6, f_num(avgR) + "R", text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 7, "PF", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 7, f_num(pf), text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 8, "Max DD", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 8, str.tostring(simMaxDdR, "#.##") + "R", text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 9, "状態", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 9, simInTrade ? "IN " + f_rank_text(simRankScore) : simPending ? "NEXT " + f_rank_text(pendingRankScore) : "WAIT", text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 10, "Last rank", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 10, lastSignalRank, text_color=lastSignalRank == "A+" ? color.lime : lastSignalRank == "A" ? color.white : color.yellow, text_size=size.tiny)
    table.cell(t, 0, 11, "Action", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 11, actionText, text_color=(actionText == "GO A+" or actionText == "GO A") ? color.lime : actionText == "SELECT A" ? color.yellow : actionText == "OBS B" ? color.white : color.red, text_size=size.tiny)
    table.cell(t, 0, 12, "Entry hour", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 12, str.tostring(entryHour) + (isExcludedHour ? " 除外" : " OK"), text_color=isExcludedHour ? color.red : color.white, text_size=size.tiny)
    table.cell(t, 0, 13, "H4", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 13, h4NotOppose ? "not oppose" : "oppose", text_color=h4NotOppose ? color.lime : color.red, text_size=size.tiny)
    table.cell(t, 0, 14, "W1", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 14, na(wave1AtrRatio) ? "N/A" : str.tostring(wave1AtrRatio, "#.#") + "ATR / " + str.tostring(wave1Speed, "#.##"), text_color=wave1QualityOk ? color.lime : color.red, text_size=size.tiny)
    table.cell(t, 0, 15, "Ret", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 15, na(retrace) ? "N/A" : str.tostring(retrace * 100.0, "#.#") + "% <= " + str.tostring(retraceMaxEff * 100.0, "#.#"), text_color=retraceOk ? color.lime : color.white, text_size=size.tiny)
    table.cell(t, 0, 16, "Box", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 16, na(boxWidth) or na(atrValue) ? "N/A" : str.tostring(boxWidth / atrValue, "#.##") + "ATR", text_color=boxOk ? color.lime : color.white, text_size=size.tiny)
    table.cell(t, 0, 17, "Break", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 17, breakStrongClose ? "strong" : breakOkClose ? "ok" : "weak/wick", text_color=(breakStrongClose or breakOkClose) ? color.lime : color.yellow, text_size=size.tiny)
    table.cell(t, 0, 18, "Phase", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 18, earlyOrNormal ? "early/normal" : "late/chase", text_color=earlyOrNormal ? color.lime : color.yellow, text_size=size.tiny)
    table.cell(t, 0, 19, "Preset", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 19, rulePreset, text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 20, "1波剪定", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 20, useWave1Quality ? "ON " + wave1QualityPreset : "OFF", text_color=useWave1Quality ? color.lime : color.yellow, text_size=size.tiny)
    table.cell(t, 0, 21, "注文rank", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 21, orderMinRank, text_color=color.white, text_size=size.tiny)
