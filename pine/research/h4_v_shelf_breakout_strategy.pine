//@version=5
strategy("H4 V Shelf Breakout [Research]",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     pyramiding=0,
     calc_on_order_fills=true,
     calc_on_every_tick=false,
     process_orders_on_close=false,
     commission_type=strategy.commission.percent,
     commission_value=0.0,
     slippage=2,
     max_bars_back=5000,
     max_lines_count=500,
     max_labels_count=500)

// =====================================================================
// H4 V Shelf Breakout [Research]
// ---------------------------------------------------------------------
// New idea from visual observations:
//   Do not buy the V bottom and do not buy the first recovery candle.
//   Buy only when a sharp selloff is rejected, price reclaims the middle
//   of the drop, then builds a tight upper shelf and breaks that shelf.
//
// Core pattern:
//   1. Prior upward or recovery regime.
//   2. Confirmed pivot high -> pivot low sharp drop.
//   3. Fast reclaim of 65%+ of the drop.
//   4. Shelf: several H4 bars hold above the drop midpoint and compress.
//   5. Entry: close breaks shelf high with body/close-location quality.
//
// Pine-first research prototype. Run on H4 for the cleanest reading.
// =====================================================================

grpMode = "基本"
requireH4 = input.bool(true, "H4チャートのみ売買", group=grpMode)
skipHoliday = input.bool(true, "12/15〜1/10は新規停止", group=grpMode)
trendMode = input.string("H4かつD1", "地合いフィルタ", options=["なし","H4","D1","H4またはD1","H4かつD1"], group=grpMode)

grpV = "Vショック条件"
pivotWidth = input.int(3, "Pivot幅", minval=1, maxval=20, group=grpV)
atrLen = input.int(14, "ATR期間", minval=1, group=grpV)
minSwingAtr = input.float(2.0, "Pivot間の最小スイング(ATR)", minval=0.1, step=0.1, group=grpV)
minDropAtr = input.float(3.2, "急落幅の最小ATR", minval=0.1, step=0.1, group=grpV)
minDropSpeed = input.float(0.25, "急落速度の下限(ATR/本)", minval=0.0, step=0.05, group=grpV)
minDropBars = input.int(2, "急落の最小本数", minval=1, group=grpV)
maxDropBars = input.int(24, "急落の最大本数", minval=2, group=grpV)
recoverMinFib = input.float(0.65, "回復率下限", minval=0.1, maxval=1.5, step=0.01, group=grpV)
recoverMaxFib = input.float(1.10, "回復率上限", minval=0.1, maxval=1.5, step=0.01, group=grpV)
maxRecoveryToDrop = input.float(1.80, "回復本数/下落本数の上限", minval=0.1, step=0.1, group=grpV)
maxCandidateAge = input.int(28, "候補後の最大監視本数", minval=3, maxval=120, group=grpV)
lowBreakInvalidAtr = input.float(0.20, "谷割れ失効(ATR)", minval=0.0, step=0.05, group=grpV)

grpShelf = "棚ブレイク条件"
shelfBars = input.int(5, "棚の本数", minval=3, maxval=20, group=grpShelf)
shelfRangeAtr = input.float(1.25, "棚の最大値幅(ATR)", minval=0.1, step=0.05, group=grpShelf)
shelfHoldFib = input.float(0.618, "棚の安値保持ライン", minval=0.0, maxval=1.0, step=0.001, group=grpShelf)
shelfHoldBufferAtr = input.float(0.10, "保持ライン許容(ATR)", minval=0.0, step=0.05, group=grpShelf)
breakBufferAtr = input.float(0.05, "棚上抜け余白(ATR)", minval=0.0, step=0.01, group=grpShelf)
minBodyRatio = input.float(0.45, "ブレイク足の実体比率", minval=0.0, maxval=1.0, step=0.05, group=grpShelf)
minCloseLocation = input.float(0.60, "ブレイク足の終値位置", minval=0.0, maxval=1.0, step=0.05, group=grpShelf)
maxEntryFib = input.float(1.02, "Entry回復率上限", minval=0.5, maxval=1.5, step=0.01, group=grpShelf, tooltip="元の急落開始高値を大きく超えてからの棚ブレイクは、押し目というより高値追いになりやすいため除外します。")

grpRisk = "リスク/利確"
stopBasis = input.string("棚安値", "SL基準", options=["棚安値","V谷"], group=grpRisk)
stopBufferAtr = input.float(0.25, "SL余白(ATR)", minval=0.0, step=0.05, group=grpRisk)
maxRiskAtr = input.float(2.2, "最大リスク幅(ATR)", minval=0.1, step=0.1, group=grpRisk)
rr = input.float(2.0, "TP RR", minval=0.5, step=0.1, group=grpRisk)
tpBasis = input.string("Entry基準", "TP計算", options=["Entry基準","Signal基準"], group=grpRisk)
maxHoldBars = input.int(120, "最大保有本数", minval=1, group=grpRisk)

grpTrend = "地合い詳細"
h4FastLen = input.int(20, "H4 EMA fast", minval=1, group=grpTrend)
h4SlowLen = input.int(50, "H4 EMA slow", minval=1, group=grpTrend)
d1FastLen = input.int(20, "D1 EMA fast", minval=1, group=grpTrend)
d1SlowLen = input.int(50, "D1 EMA slow", minval=1, group=grpTrend)
maxEmaStretchAtr = input.float(3.5, "EMA20からの最大乖離(ATR)", minval=0.1, step=0.1, group=grpTrend)

grpView = "表示"
showCandidates = input.bool(false, "候補表示", group=grpView, tooltip="OFF推奨。候補が多く出るため、実戦確認ではEntry/見送りを主役にします。")
showSignals = input.bool(true, "Entry表示", group=grpView)
showSkips = input.bool(true, "見送り表示", group=grpView)
showLevels = input.bool(true, "SL/TP/棚ライン", group=grpView)
showTable = input.bool(true, "状態テーブル", group=grpView)
maxLabels = input.int(80, "残すラベル数", minval=10, maxval=300, group=grpView)
labelShiftBars = input.int(0, "ラベル右ずらし", minval=0, maxval=80, group=grpView, tooltip="0推奨。シグナル足に固定してズレを防ぎます。")
labelOffsetAtr = input.float(3.0, "ラベル上下余白(ATR)", minval=0.5, step=0.5, group=grpView)

fmt(float v) =>
    string out = na(v) ? "N/A" : str.tostring(v, format.mintick)
    out

fmtNum(float v) =>
    string out = na(v) ? "N/A" : str.tostring(v, "#.##")
    out

skipText(int code) =>
    string out = code == 1 ? "H4以外" :
         code == 2 ? "地合い不足" :
         code == 3 ? "棚が広い" :
         code == 4 ? "棚の安値保持不足" :
         code == 5 ? "実体/終値位置不足" :
         code == 6 ? "リスク幅が大きい" :
         code == 7 ? "EMA乖離過大" :
         code == 8 ? "既に保有中" :
         code == 9 ? "候補が古い" :
         code == 10 ? "年末年始停止" :
         code == 11 ? "回復しすぎ" :
         "見送り"
    out

var label[] labels = array.new_label()
var line[] lines = array.new_line()

keepLabel(label lb) =>
    array.push(labels, lb)
    while array.size(labels) > maxLabels
        label.delete(array.shift(labels))

keepLine(line ln) =>
    array.push(lines, ln)
    while array.size(lines) > maxLabels * 4
        line.delete(array.shift(lines))

float atrValue = ta.atr(atrLen)
float emaFast = ta.ema(close, h4FastLen)
float emaSlow = ta.ema(close, h4SlowLen)
float d1Fast = request.security(syminfo.tickerid, "D", ta.ema(close, d1FastLen), barmerge.gaps_off, barmerge.lookahead_off)
float d1Slow = request.security(syminfo.tickerid, "D", ta.ema(close, d1SlowLen), barmerge.gaps_off, barmerge.lookahead_off)

bool h4Trend = close > emaFast and emaFast > emaSlow
bool d1Trend = d1Fast > d1Slow
bool trendOk = trendMode == "なし" ? true :
     trendMode == "H4" ? h4Trend :
     trendMode == "D1" ? d1Trend :
     trendMode == "H4またはD1" ? (h4Trend or d1Trend) :
     h4Trend and d1Trend

int chartSec = timeframe.in_seconds(timeframe.period)
bool h4Ok = not requireH4 or chartSec == 240 * 60
bool holidayOk = not skipHoliday or not ((month == 12 and dayofmonth >= 15) or (month == 1 and dayofmonth <= 10))
bool stretchOk = not na(atrValue) and atrValue > 0 and (close - emaFast) / atrValue <= maxEmaStretchAtr

float ph = ta.pivothigh(high, pivotWidth, pivotWidth)
float pl = ta.pivotlow(low, pivotWidth, pivotWidth)

var int prevKind = 0
var float prevPrice = na
var int prevIndex = na
var int prevTime = na
var float prevAtr = na

var int lastKind = 0
var float lastPrice = na
var int lastIndex = na
var int lastTime = na
var float lastAtr = na

bool newPivot = false
int pKind = 0
float pPrice = na
int pIndex = na
int pTime = na
float pAtr = na

if not na(ph) and na(pl)
    newPivot := true
    pKind := 1
    pPrice := ph
    pIndex := bar_index - pivotWidth
    pTime := time[pivotWidth]
    pAtr := atrValue[pivotWidth]
else if not na(pl) and na(ph)
    newPivot := true
    pKind := -1
    pPrice := pl
    pIndex := bar_index - pivotWidth
    pTime := time[pivotWidth]
    pAtr := atrValue[pivotWidth]

if newPivot and not na(pAtr) and pAtr > 0
    if lastKind == 0
        lastKind := pKind
        lastPrice := pPrice
        lastIndex := pIndex
        lastTime := pTime
        lastAtr := pAtr
    else if pKind == lastKind
        bool moreExtreme = (pKind == 1 and pPrice > lastPrice) or (pKind == -1 and pPrice < lastPrice)
        if moreExtreme
            lastPrice := pPrice
            lastIndex := pIndex
            lastTime := pTime
            lastAtr := pAtr
    else
        float swing = math.abs(pPrice - lastPrice)
        float threshold = math.max(pAtr, lastAtr) * minSwingAtr
        if swing >= threshold
            prevKind := lastKind
            prevPrice := lastPrice
            prevIndex := lastIndex
            prevTime := lastTime
            prevAtr := lastAtr
            lastKind := pKind
            lastPrice := pPrice
            lastIndex := pIndex
            lastTime := pTime
            lastAtr := pAtr

float shelfHighPrev = ta.highest(high[1], shelfBars)
float shelfLowPrev = ta.lowest(low[1], shelfBars)
float shelfRange = shelfHighPrev - shelfLowPrev
float barRange = high - low
float bodyRatio = barRange > 0 ? math.abs(close - open) / barRange : 0.0
float closeLocation = barRange > 0 ? (close - low) / barRange : 0.0

var int activePrevIndex = na
var int activeLastIndex = na
var bool pairInvalid = false
var bool candidateActive = false
var int candidateIndex = na
var int candidateTime = na
var float candidateClose = na

bool candidateNow = false
bool breakoutNow = false
bool signalNow = false
int skipCode = 0
float signalStop = na
float signalTarget = na
float signalRiskAtr = na
float dropAtr = na
float dropSpeed = na
float recoverFib = na
float recoveryToDrop = na
int dropBars = na
int recoveryBars = na
int candidateAge = na

bool vPair = prevKind == 1 and lastKind == -1 and not na(prevIndex) and not na(lastIndex) and prevPrice > lastPrice
bool newPair = vPair and (na(activePrevIndex) or na(activeLastIndex) or activePrevIndex != prevIndex or activeLastIndex != lastIndex)
if newPair
    activePrevIndex := prevIndex
    activeLastIndex := lastIndex
    pairInvalid := false
    candidateActive := false
    candidateIndex := na
    candidateTime := na
    candidateClose := na

if vPair and not na(atrValue) and atrValue > 0
    float drop = prevPrice - lastPrice
    dropBars := math.max(lastIndex - prevIndex, 1)
    recoveryBars := math.max(bar_index - lastIndex, 1)
    dropAtr := drop / atrValue
    dropSpeed := drop / dropBars / atrValue
    recoverFib := drop > 0 ? (close - lastPrice) / drop : na
    float prevRecoverFib = drop > 0 ? (close[1] - lastPrice) / drop : na
    recoveryToDrop := recoveryBars / dropBars
    bool dropOk = dropAtr >= minDropAtr and dropSpeed >= minDropSpeed and dropBars >= minDropBars and dropBars <= maxDropBars
    bool lowBroken = low < lastPrice - atrValue * lowBreakInvalidAtr
    if lowBroken
        pairInvalid := true
        candidateActive := false
    if not pairInvalid and dropOk
        if not candidateActive
            bool inRecoverZone = recoverFib >= recoverMinFib and recoverFib <= recoverMaxFib
            bool crossedRecover = na(prevRecoverFib) ? inRecoverZone : prevRecoverFib < recoverMinFib and inRecoverZone
            if crossedRecover and recoveryToDrop <= maxRecoveryToDrop
                candidateActive := true
                candidateIndex := bar_index
                candidateTime := time
                candidateClose := close
                candidateNow := true
        else
            candidateAge := bar_index - candidateIndex
            if candidateAge > maxCandidateAge
                candidateActive := false
                pairInvalid := true
                skipCode := 9
            else
                float holdLine = lastPrice + drop * shelfHoldFib
                bool enoughShelfBars = candidateAge >= shelfBars
                bool shelfTight = shelfRange <= atrValue * shelfRangeAtr
                bool shelfHolds = shelfLowPrev >= holdLine - atrValue * shelfHoldBufferAtr
                breakoutNow := enoughShelfBars and close > shelfHighPrev + atrValue * breakBufferAtr
                bool entryNotTooLate = recoverFib <= maxEntryFib
                bool breakQuality = bodyRatio >= minBodyRatio and closeLocation >= minCloseLocation
                float stopFromShelf = shelfLowPrev - atrValue * stopBufferAtr
                float stopFromV = lastPrice - atrValue * stopBufferAtr
                signalStop := stopBasis == "棚安値" ? stopFromShelf : stopFromV
                float riskDist = close - signalStop
                signalRiskAtr := riskDist / atrValue
                signalTarget := close + riskDist * rr
                skipCode := not h4Ok ? 1 :
                     not trendOk ? 2 :
                     not shelfTight ? 3 :
                     not shelfHolds ? 4 :
                     not breakQuality ? 5 :
                     riskDist <= 0 or signalRiskAtr > maxRiskAtr ? 6 :
                     not stretchOk ? 7 :
                     strategy.position_size != 0 ? 8 :
                     not holidayOk ? 10 :
                     not entryNotTooLate ? 11 :
                     0
                signalNow := breakoutNow and skipCode == 0
                if signalNow
                    candidateActive := false
                    pairInvalid := true

bool newCandidate = candidateNow
bool newSignal = signalNow
bool newSkip = breakoutNow and not signalNow and showSkips

plotshape(showCandidates and newCandidate, title="V Shelf Candidate", style=shape.circle, location=location.belowbar, color=color.new(color.aqua, 0), size=size.tiny, text="V棚")
plotshape(newSignal, title="V Shelf Breakout Long", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="棚B")
plotshape(newSkip, title="V Shelf Skip", style=shape.xcross, location=location.abovebar, color=color.new(color.gray, 0), size=size.tiny, text="見送り")

float labelAtr = ta.atr(14)
int barMs = timeframe.in_seconds(timeframe.period) * 1000
int labelTime = time + barMs * labelShiftBars
int levelEndTime = time + barMs * 20
if newCandidate and showCandidates
    string cTxt = "V棚候補\nFib: " + fmtNum(recoverFib) + "\nDrop: " + fmtNum(dropAtr) + "ATR"
    keepLabel(label.new(labelTime, low - labelAtr * labelOffsetAtr, cTxt, xloc=xloc.bar_time, style=label.style_label_up, color=color.new(color.aqua, 0), textcolor=color.black, size=size.tiny))
    if showLevels
        keepLine(line.new(prevTime, prevPrice, lastTime, lastPrice, xloc=xloc.bar_time, color=color.new(color.red, 0), width=2))
        keepLine(line.new(lastTime, lastPrice, time, close, xloc=xloc.bar_time, color=color.new(color.aqua, 0), width=2))

if newSkip
    string sTxt = "見送り\n" + skipText(skipCode)
    keepLabel(label.new(labelTime, high + labelAtr * labelOffsetAtr, sTxt, xloc=xloc.bar_time, style=label.style_label_down, color=color.new(color.gray, 10), textcolor=color.white, size=size.tiny))

if newSignal and showSignals
    string eTxt = "V棚ブレイク\nE: next open\nSL: " + fmt(signalStop) + "\nTP: " + fmt(signalTarget) + "\nRisk: " + fmtNum(signalRiskAtr) + "ATR"
    keepLabel(label.new(labelTime, low - labelAtr * labelOffsetAtr, eTxt, xloc=xloc.bar_time, style=label.style_label_up, color=color.new(color.lime, 0), textcolor=color.black, size=size.tiny))
    if showLevels
        keepLine(line.new(time[shelfBars], shelfHighPrev, time, shelfHighPrev, xloc=xloc.bar_time, color=color.new(color.yellow, 0), width=2))
        keepLine(line.new(time[shelfBars], shelfLowPrev, time, shelfLowPrev, xloc=xloc.bar_time, color=color.new(color.orange, 0), width=1))
        keepLine(line.new(time, signalStop, levelEndTime, signalStop, xloc=xloc.bar_time, color=color.new(color.red, 0), width=2, style=line.style_dashed))
        keepLine(line.new(time, signalTarget, levelEndTime, signalTarget, xloc=xloc.bar_time, color=color.new(color.lime, 0), width=2, style=line.style_dashed))

var float pendingStop = na
var float pendingTarget = na
var float activeStop = na
var float activeTarget = na
var int entryBar = na

if newSignal and strategy.position_size == 0
    pendingStop := signalStop
    pendingTarget := signalTarget
    strategy.entry("Long", strategy.long)

if strategy.position_size > 0 and strategy.position_size[1] <= 0
    activeStop := pendingStop
    activeTarget := tpBasis == "Entry基準" ? strategy.position_avg_price + (strategy.position_avg_price - activeStop) * rr : pendingTarget
    entryBar := bar_index

if strategy.position_size > 0 and not na(activeStop) and not na(activeTarget)
    strategy.exit("L-Exit", from_entry="Long", stop=activeStop, limit=activeTarget)
    if not na(entryBar) and bar_index - entryBar >= maxHoldBars
        strategy.close("Long", comment="MaxHold")

if strategy.position_size == 0 and strategy.position_size[1] > 0
    activeStop := na
    activeTarget := na
    entryBar := na

plot(strategy.position_size > 0 ? activeStop : na, title="Active SL", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(strategy.position_size > 0 ? activeTarget : na, title="Active TP", color=color.new(color.lime, 0), linewidth=2, style=plot.style_linebr)
plot(candidateActive ? shelfHighPrev : na, title="Shelf High", color=color.new(color.yellow, 0), linewidth=1, style=plot.style_linebr)
plot(candidateActive ? shelfLowPrev : na, title="Shelf Low", color=color.new(color.orange, 20), linewidth=1, style=plot.style_linebr)

var table t = table.new(position.bottom_left, 2, 12, bgcolor=color.new(color.black, 80), border_color=color.gray, border_width=1)
if showTable and barstate.islast
    table.cell(t, 0, 0, "Method", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 0, "V Shelf Breakout", text_color=color.lime, text_size=size.tiny)
    table.cell(t, 0, 1, "Chart", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 1, h4Ok ? "OK" : "H4以外", text_color=h4Ok ? color.lime : color.red, text_size=size.tiny)
    table.cell(t, 0, 2, "State", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, candidateActive ? "棚待ち" : vPair and not pairInvalid ? "V監視" : "N/A", text_color=candidateActive ? color.aqua : color.gray, text_size=size.tiny)
    table.cell(t, 0, 3, "Trend", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, trendOk ? "OK" : "NG", text_color=trendOk ? color.lime : color.orange, text_size=size.tiny)
    table.cell(t, 0, 4, "Recover", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, fmtNum(recoverFib), text_color=color.aqua, text_size=size.tiny)
    table.cell(t, 0, 5, "Drop ATR", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 5, fmtNum(dropAtr), text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 6, "Shelf rng", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 6, fmtNum(shelfRange / atrValue), text_color=shelfRange <= atrValue * shelfRangeAtr ? color.lime : color.orange, text_size=size.tiny)
    table.cell(t, 0, 7, "Body/Loc", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 7, fmtNum(bodyRatio) + "/" + fmtNum(closeLocation), text_color=bodyRatio >= minBodyRatio and closeLocation >= minCloseLocation ? color.lime : color.gray, text_size=size.tiny)
    table.cell(t, 0, 8, "Risk ATR", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 8, fmtNum(signalRiskAtr), text_color=not na(signalRiskAtr) and signalRiskAtr <= maxRiskAtr ? color.lime : color.orange, text_size=size.tiny)
    table.cell(t, 0, 9, "Last skip", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 9, skipCode == 0 ? "OK/待機" : skipText(skipCode), text_color=skipCode == 0 ? color.lime : color.orange, text_size=size.tiny)
    table.cell(t, 0, 10, "Position", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 10, strategy.position_size > 0 ? "LONG" : "FLAT", text_color=strategy.position_size > 0 ? color.lime : color.gray, text_size=size.tiny)
    table.cell(t, 0, 11, "Holiday", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 11, holidayOk ? "OK" : "STOP", text_color=holidayOk ? color.lime : color.orange, text_size=size.tiny)

alertcondition(newCandidate, title="H4 V Shelf Candidate", message="H4 V shelf candidate on {{ticker}} {{interval}}")
alertcondition(newSignal, title="H4 V Shelf Breakout Long", message="H4 V shelf breakout long on {{ticker}} {{interval}}")
