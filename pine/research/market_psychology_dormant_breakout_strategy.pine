//@version=5
// =============================================================================
// Market Psychology — Dormant Breakout Strategy (Pattern 10, 両方向)
//
// 心理仮説:
//   数ヶ月〜数年触れていない節目を抜けると、長く積み上がった逆指値
//   (stop orders) と、新規参加者の FOMO が同時に発火して大きく動く。
//   これは Pain Trade + FOMO の合成 (パターン辞書 #9 + #7)。
//
// 設計書:
//   backtests/.../market_psychology_v2_deep_research/r6_dormant_breakout_plan.md
//
// 構造 (両方向):
//   ① Donchian-N の高安値が N 本タッチされず休眠
//   ② 終値が休眠節目を破る (ヒゲのみは採用しない)
//   ③ 5 本以内の押し戻りが破った節目を保持
//   ④ 押し戻りの高安値を再ブレイク → エントリー
//
// 検証ステータス: ⚠️ Python 検証は未実施。TradingView Strategy Tester で初期確認 + フォワード。
//
// 推奨時間足: H4 / D1。N = 120 / 360 / 1250 の 3 つを切替検証。
// =============================================================================
strategy("本命v2 Market Psychology Dormant Breakout [両方向]",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     pyramiding=0,
     calc_on_order_fills=true,
     calc_on_every_tick=false,
     process_orders_on_close=false,
     commission_type=strategy.commission.percent,
     commission_value=0.0,
     slippage=2,
     max_bars_back=5000,
     max_lines_count=500,
     max_labels_count=500)

plot(na, title="Compiler Anchor", display=display.none)

// ---------------------------------------------------------------------
// Common
// ---------------------------------------------------------------------
grpG       = "共通"
allowH4    = input.bool(true,  "H4 を許可", group=grpG)
allowD1    = input.bool(true,  "D1 を許可", group=grpG)
useDate    = input.bool(true,  "2015〜2026のみ", group=grpG)
atrLen     = input.int(14,     "ATR期間", minval=1, group=grpG)
rr         = input.float(2.0,  "TP RR", minval=0.1, step=0.1, group=grpG)
stopBufATR = input.float(0.25, "SL余白(ATR)", minval=0.0, step=0.05, group=grpG)
maxHold    = input.int(240,    "最大保有(本)", minval=10, group=grpG)
riskPct    = input.float(1.0,  "1トレードのリスク(%)", minval=0.01, step=0.1, group=grpG)
excludeGBP = input.bool(true,  "GBPJPYを除外", group=grpG)

// ---------------------------------------------------------------------
// Method selection
// ---------------------------------------------------------------------
grpDir = "方向"
useLong  = input.bool(true,  "ロング: 休眠高値ブレイク", group=grpDir)
useShort = input.bool(true,  "ショート: 休眠安値ブレイク", group=grpDir)

// ---------------------------------------------------------------------
// Dormancy
// ---------------------------------------------------------------------
grpD  = "休眠 (Dormancy)"
dormN = input.int(120, "休眠期間 N (本)", minval=20, group=grpD,
     tooltip="Donchian-N の高安値が直前 N 本でタッチされていないこと")

// ---------------------------------------------------------------------
// Pullback / re-break
// ---------------------------------------------------------------------
grpPB = "押し戻り / 再ブレイク"
pbWin = input.int(5, "押し戻り窓 (本)", minval=2, maxval=20, group=grpPB)

// ---------------------------------------------------------------------
// Optional volume
// ---------------------------------------------------------------------
grpV = "Volume (任意)"
useVol = input.bool(false, "Volume: vol > sma(20)*X", group=grpV)
volLen = input.int(20, "Volume平均期間", group=grpV)
volMult = input.float(1.3, "Volume 倍率", group=grpV)

// ---------------------------------------------------------------------
// Common
// ---------------------------------------------------------------------
atr = ta.atr(atrLen)

int chartSec = timeframe.in_seconds(timeframe.period)
bool tfOk    = (allowH4 and chartSec == 240*60) or (allowD1 and chartSec == 1440*60)
bool dateOk  = not useDate or (year >= 2015 and year <= 2026)
bool symOk   = not excludeGBP or not str.contains(syminfo.ticker, "GBPJPY")

float volAvg = ta.sma(volume, volLen)
bool  volOk  = not useVol or (not na(volAvg) and volume > volAvg * volMult)

// ---------------------------------------------------------------------
// Long: Donchian-N high not touched for N bars, then close breaks it,
//       then a 5-bar pullback holds above the level, then re-breaks the
//       pullback high
// ---------------------------------------------------------------------
// The dormant level is the Donchian-N high from N+pbWin bars ago, computed
// before any of the recent action.  We check that all bars from N+pbWin..1
// (i.e. before the break + pullback) stayed strictly below this level.
float donHi_long = ta.highest(high, dormN)[1 + pbWin]
// Establish the moment of break: the most recent N bars include a bar where
// close > donHi_long.  We use the bar where the break happened to anchor
// the pullback window.
// We approximate: the bar with the highest close in the last pbWin*3 bars,
// whose close exceeded donHi_long, is the break bar.  Then the pullback is
// the next pbWin bars where lows held above donHi_long.
int lookBack = pbWin * 3
float maxCloseBack = ta.highest(close, lookBack)[1]
bool breakHappened_long = maxCloseBack > donHi_long
// Pullback held: in the last pbWin bars, the lowest low was above the donHi.
float pbLowestLong = ta.lowest(low, pbWin)[1]
bool pbHeldLong = pbLowestLong >= donHi_long
// Re-break: pullback high break by current close
float pbHighLong = ta.highest(high, pbWin)[1]
bool reBreakLong = close[1] <= pbHighLong and close > pbHighLong

bool ready = tfOk and dateOk and symOk and volOk and not na(atr) and atr > 0
bool longSig = useLong and ready and breakHappened_long and pbHeldLong and reBreakLong
            and strategy.position_size == 0
float longStop = pbLowestLong - stopBufATR * atr

// ---------------------------------------------------------------------
// Short (mirror)
// ---------------------------------------------------------------------
float donLo_short = ta.lowest(low, dormN)[1 + pbWin]
float minCloseBack = ta.lowest(close, lookBack)[1]
bool breakHappened_short = minCloseBack < donLo_short
float pbHighestShort = ta.highest(high, pbWin)[1]
bool pbHeldShort = pbHighestShort <= donLo_short
float pbLowShort = ta.lowest(low, pbWin)[1]
bool reBreakShort = close[1] >= pbLowShort and close < pbLowShort

bool shortSig = useShort and ready and breakHappened_short and pbHeldShort and reBreakShort
             and strategy.position_size == 0
float shortStop = pbHighestShort + stopBufATR * atr

// ---------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------
var float activeStop = na
var bool  isLong     = false

if longSig
    float dist = close - longStop
    if dist > 0
        float qty = (strategy.equity * (riskPct / 100.0)) / dist
        activeStop := longStop
        isLong := true
        strategy.entry("L", strategy.long, qty=qty)

if shortSig
    float dist = shortStop - close
    if dist > 0
        float qty = (strategy.equity * (riskPct / 100.0)) / dist
        activeStop := shortStop
        isLong := false
        strategy.entry("S", strategy.short, qty=qty)

if strategy.position_size != 0 and not na(activeStop)
    if isLong
        float risk0 = strategy.position_avg_price - activeStop
        if risk0 > 0
            float target = strategy.position_avg_price + rr * risk0
            strategy.exit("X", from_entry="L", stop=activeStop, limit=target)
    else
        float risk0 = activeStop - strategy.position_avg_price
        if risk0 > 0
            float target = strategy.position_avg_price - rr * risk0
            strategy.exit("X", from_entry="S", stop=activeStop, limit=target)
    if strategy.opentrades > 0 and bar_index - strategy.opentrades.entry_bar_index(0) >= maxHold
        strategy.close_all(comment="timeout")

if strategy.position_size == 0 and strategy.position_size[1] != 0
    activeStop := na

// ---------------------------------------------------------------------
// Visuals
// ---------------------------------------------------------------------
plot(donHi_long,   title="休眠高値 (Dormant High)", color=color.new(color.orange, 50),
     style=plot.style_circles, linewidth=1)
plot(donLo_short,  title="休眠安値 (Dormant Low)",  color=color.new(color.purple, 50),
     style=plot.style_circles, linewidth=1)

plotshape(longSig,  title="Dormant Long",  style=shape.triangleup,
     location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="DBL")
plotshape(shortSig, title="Dormant Short", style=shape.triangledown,
     location=location.abovebar, color=color.new(color.red, 0),  size=size.small, text="DBS")

alertcondition(longSig,  title="Dormant Breakout Long",
     message="Dormant Breakout LONG on {{ticker}} {{interval}} @ {{close}}")
alertcondition(shortSig, title="Dormant Breakout Short",
     message="Dormant Breakout SHORT on {{ticker}} {{interval}} @ {{close}}")
