//@version=5
// =============================================================================
// Market Psychology v2.1 — Currency × Structure Matrix Strategy
//
// 通貨ごとに最適な心理構造 (Squeeze / Capitulation / Long Liquidation) を
// 自動で ON/OFF する統合ストラテジー。
//
// チャートにこの 1 本を載せるだけで、その通貨の最適構造だけが動作。
//
// 採用マトリクス (TradingView Strategy Tester での実測, STEP 1+2+3 由来):
//
//   ┌──────────┬───────┬───────┬───────┐
//   │ Symbol   │ Sqz   │ Cap   │ LL    │
//   ├──────────┼───────┼───────┼───────┤
//   │ XAUUSD   │  ✅   │  ❌   │  ❌   │  Sqz 単独 (+0.98%)
//   │ XAGUSD   │  ✅   │  ❌   │  ❌   │  Sqz 単独 (+7.16%)
//   │ EURJPY   │  ✅   │  ✅   │  ❌   │  Sqz + Cap (+4.55%)
//   │ AUDJPY   │  ✅   │  ✅   │  ❌   │  Sqz + Cap (+4.22%)
//   │ USDJPY   │  ❌   │  ✅   │  ✅   │  Cap + LL (+21.99%, USDJPY が本命!)
//   │ CHFJPY   │  ✅   │  ✅   │  ✅   │  3 構造全部 (+11.04%)
//   │ GBPJPY   │  ❌   │  ❌   │  ❌   │  全構造で除外
//   └──────────┴───────┴───────┴───────┘
//
// 期待: 6 通貨に乗せた時の合算 Net +49.94% (個別 100% 換算、STEP 1+2+3 実測)
//
// 関連:
//   pine/research/market_psychology_strict_v2_strategy.pine        (Sqz + Cap)
//   pine/research/market_psychology_long_liquidation_strategy.pine (LL)
//   docs/research/market_psychology/forward_log_2026_05_step{1,2,3}.md
//
// 推奨時間足: H4
// =============================================================================
strategy("本命v2.1 Market Psychology Matrix (Sqz + Cap + LL)",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     pyramiding=0,
     calc_on_order_fills=true,
     calc_on_every_tick=false,
     process_orders_on_close=false,
     commission_type=strategy.commission.percent,
     commission_value=0.0,
     slippage=2,
     max_bars_back=5000,
     max_lines_count=500,
     max_labels_count=500)

plot(na, title="Compiler Anchor", display=display.none)

// ---------------------------------------------------------------------
// Common
// ---------------------------------------------------------------------
grpG       = "共通"
requireH4  = input.bool(true,  "H4 チャートのみ売買", group=grpG)
useDate    = input.bool(true,  "2015 〜 2026 のみ",   group=grpG)
atrLen     = input.int(14,     "ATR 期間",            minval=1, group=grpG)
rr         = input.float(2.0,  "TP RR",               minval=0.1, step=0.1, group=grpG)
stopBufATR = input.float(0.25, "SL 余白 (ATR)",       minval=0.0, step=0.05, group=grpG)
maxHold    = input.int(120,    "最大保有 (本)",       minval=10, group=grpG)
riskPct    = input.float(1.0,  "1 トレードのリスク (%)", minval=0.01, step=0.1, group=grpG)

// ---------------------------------------------------------------------
// Matrix mode (auto / manual)
// ---------------------------------------------------------------------
grpM = "マトリクスモード"
autoMatrix = input.bool(true, "シンボル別に自動 ON/OFF", group=grpM,
     tooltip="OFF にすると下の手動チェックボックスが効く")
manualSqz  = input.bool(true,  "[手動] ① Squeeze",        group=grpM)
manualCap  = input.bool(false, "[手動] ② Capitulation",   group=grpM)
manualLL   = input.bool(false, "[手動] ③ Long Liquidation", group=grpM)

// ---------------------------------------------------------------------
// Symbol classification (matrix)
// ---------------------------------------------------------------------
string sym = syminfo.ticker
bool isXAUUSD = str.contains(sym, "XAUUSD") or str.contains(sym, "GOLD")
bool isXAGUSD = str.contains(sym, "XAGUSD") or str.contains(sym, "SILVER")
bool isEURJPY = str.contains(sym, "EURJPY")
bool isAUDJPY = str.contains(sym, "AUDJPY")
bool isUSDJPY = str.contains(sym, "USDJPY")
bool isCHFJPY = str.contains(sym, "CHFJPY")
bool isGBPJPY = str.contains(sym, "GBPJPY")

bool autoSqz = isXAUUSD or isXAGUSD or isEURJPY or isAUDJPY or isCHFJPY
bool autoCap = isEURJPY or isAUDJPY or isUSDJPY or isCHFJPY
bool autoLL  = isUSDJPY or isCHFJPY
// GBPJPY と未分類は全て false (除外扱い)

bool useSqz = autoMatrix ? autoSqz : manualSqz
bool useCap = autoMatrix ? autoCap : manualCap
bool useLL  = autoMatrix ? autoLL  : manualLL
bool symKnown = isXAUUSD or isXAGUSD or isEURJPY or isAUDJPY or isUSDJPY or isCHFJPY or isGBPJPY

// ---------------------------------------------------------------------
// Squeeze v2 params
// ---------------------------------------------------------------------
grpS      = "① 踏み上げ Squeeze v2"
shelfBars = input.int(6, "棚の本数", minval=2, group=grpS)
dropWin   = input.int(6, "棚直前の急変窓", minval=2, group=grpS)
shelfAtr  = input.float(2.2, "棚幅上限 (ATR)", minval=0.5, step=0.1, group=grpS)
dropAtr   = input.float(4.0, "急落幅下限 (ATR)", minval=1.0, step=0.1, group=grpS)

// ---------------------------------------------------------------------
// Capitulation v2 params
// ---------------------------------------------------------------------
grpC      = "② 投げ切り Capitulation v2"
declBars  = input.int(24, "長期下落の窓", minval=4, group=grpC)
dropAtrC  = input.float(4.0, "下落幅 >= ?×ATR", minval=1.0, step=0.1, group=grpC)
sigRngC   = input.float(3.0, "クライマックス足値幅 >= ?×ATR", minval=0.5, step=0.1, group=grpC)
wickThr   = input.float(0.5, "下ヒゲ/全体 >=", minval=0.0, maxval=1.0, step=0.05, group=grpC)
closeLocC = input.float(0.5, "終値位置 >=", minval=0.0, maxval=1.0, step=0.05, group=grpC)
useDownD1 = input.bool(true, "日足下降中のみ", group=grpC)

// ---------------------------------------------------------------------
// Long Liquidation v1 params
// ---------------------------------------------------------------------
grpL       = "③ Long Liquidation v1"
rallyBars  = input.int(6,   "急騰の窓", minval=3, group=grpL)
rallyPrior = input.int(12,  "急騰の比較窓", minval=6, group=grpL)
rallyAtr   = input.float(3.0, "急騰幅 >= ?×ATR", minval=1.0, step=0.1, group=grpL)
shelfBarsL = input.int(6,   "棚の本数 (LL)", minval=2, group=grpL)
shelfAtrL  = input.float(2.0, "棚幅上限 ATR (LL)", minval=0.5, step=0.1, group=grpL)

// ---------------------------------------------------------------------
// Optional v2 filters
// ---------------------------------------------------------------------
grpV2     = "v2 追加フィルタ (任意)"
useEarly  = input.bool(true,  "早期撤退: MFE < X*R after N bars", group=grpV2)
earlyMfeR = input.float(0.5,  "早期撤退 MFE 閾値 (R)", minval=0.1, step=0.05, group=grpV2)
earlyBars = input.int(12,     "早期撤退 経過バー数", minval=2, group=grpV2)
earlyLossR = input.float(0.35, "早期撤退 損 (R)", minval=0.05, step=0.05, group=grpV2)

useHour  = input.bool(false, "時間フィルタ: 4/8/16/20 UTC のみ", group=grpV2)
useVol   = input.bool(false, "Volume: vol > sma(20)*X", group=grpV2)
volLen   = input.int(20, "Volume 平均期間", minval=2, group=grpV2)
volMult  = input.float(1.3, "Volume 倍率", minval=0.5, step=0.1, group=grpV2)

// ---------------------------------------------------------------------
// Common indicators
// ---------------------------------------------------------------------
atr   = ta.atr(atrLen)
rng   = high - low
rngOk = rng > 0

int chartSec = timeframe.in_seconds(timeframe.period)
bool h4Ok    = not requireH4 or chartSec == 240 * 60
bool dateOk  = not useDate or (year >= 2015 and year <= 2026)
bool hourOk  = not useHour or hour == 4 or hour == 8 or hour == 16 or hour == 20

float volAvg = ta.sma(volume, volLen)
bool  volOk  = not useVol or (not na(volAvg) and volume > volAvg * volMult)
bool atrOk   = not na(atr) and atr > 0

bool baseReady = h4Ok and dateOk and hourOk and volOk and atrOk and symKnown

// ---------------------------------------------------------------------
// ① Squeeze (long)
// ---------------------------------------------------------------------
float shelfHi  = ta.highest(high, shelfBars)[1]
float shelfLo  = ta.lowest(low,  shelfBars)[1]
float priorHiS = ta.highest(high, dropWin)[1 + shelfBars]

bool sqzCompr = (shelfHi - shelfLo) <= shelfAtr * atr
bool sqzSharp = (priorHiS - shelfHi) >= dropAtr * atr
bool sqzFresh = close[1] <= shelfHi and close > shelfHi

bool sqzLong  = useSqz and baseReady and sqzCompr and sqzSharp and sqzFresh and strategy.position_size == 0
float sqzStop = shelfLo - stopBufATR * atr

// ---------------------------------------------------------------------
// ② Capitulation (long)
// ---------------------------------------------------------------------
bool capNewLow   = low <= ta.lowest(low, declBars)
bool capProlong  = (ta.highest(high, declBars) - low) >= dropAtrC * atr
bool capBig      = rng >= sigRngC * atr
bool capWick     = rngOk and ((math.min(open, close) - low) / rng) >= wickThr
bool capCloseLoc = rngOk and ((close - low) / rng) >= closeLocC

float d1ema = request.security(syminfo.tickerid, "D", ta.ema(close, 50)[1], lookahead=barmerge.lookahead_off)
bool capDown = not useDownD1 or close < d1ema

bool capStructOk = capNewLow and capProlong and capBig and capWick and capCloseLoc and capDown
bool capLong     = useCap and baseReady and capStructOk and strategy.position_size == 0
float capStop    = low - stopBufATR * atr

// ---------------------------------------------------------------------
// ③ Long Liquidation (short)
// ---------------------------------------------------------------------
float rallyHigh = ta.highest(high, rallyBars)[1]
float rallyLow  = ta.lowest(low, rallyPrior)[1 + rallyBars]
bool  hadRally  = (rallyHigh - rallyLow) >= rallyAtr * atr

float shelfHiL = ta.highest(high, shelfBarsL)[1]
float shelfLoL = ta.lowest(low,  shelfBarsL)[1]
bool  compressedL = (shelfHiL - shelfLoL) <= shelfAtrL * atr

float swingHi = ta.highest(high, rallyBars + shelfBarsL)[1]
bool failedNewHigh = shelfHiL < swingHi - 0.05 * atr
bool freshBreakL = close[1] >= shelfLoL and close < shelfLoL

bool llShort = useLL and baseReady and hadRally and compressedL and failedNewHigh and freshBreakL and strategy.position_size == 0
float llStop = shelfHiL + stopBufATR * atr

// ---------------------------------------------------------------------
// Order routing (long-side has priority over short-side on same bar)
// ---------------------------------------------------------------------
var float activeStop = na
var int   entryBar   = na
var bool  posIsLong  = false

bool longSig  = sqzLong or capLong
bool shortSig = llShort and not longSig

float longStop = sqzLong ? sqzStop : capStop

if longSig
    float dist = close - longStop
    if dist > 0
        float qty = (strategy.equity * (riskPct / 100.0)) / dist
        activeStop := longStop
        entryBar   := bar_index
        posIsLong  := true
        strategy.entry("L", strategy.long, qty=qty)

if shortSig
    float dist = llStop - close
    if dist > 0
        float qty = (strategy.equity * (riskPct / 100.0)) / dist
        activeStop := llStop
        entryBar   := bar_index
        posIsLong  := false
        strategy.entry("S", strategy.short, qty=qty)

// Exit + early exit
if strategy.position_size != 0 and not na(activeStop)
    if posIsLong
        float risk0 = strategy.position_avg_price - activeStop
        if risk0 > 0
            float target = strategy.position_avg_price + rr * risk0
            strategy.exit("X", from_entry="L", stop=activeStop, limit=target)
            if useEarly and not na(entryBar)
                int barsHeld = bar_index - entryBar
                float mfeR = (ta.highest(high, barsHeld + 1) - strategy.position_avg_price) / risk0
                if barsHeld >= earlyBars and mfeR < earlyMfeR
                    strategy.close("L", comment="early_exit_mfe")
            if strategy.opentrades > 0 and bar_index - strategy.opentrades.entry_bar_index(0) >= maxHold
                strategy.close("L", comment="timeout")
    else
        float risk0 = activeStop - strategy.position_avg_price
        if risk0 > 0
            float target = strategy.position_avg_price - rr * risk0
            strategy.exit("X", from_entry="S", stop=activeStop, limit=target)
            if useEarly and not na(entryBar)
                int barsHeld = bar_index - entryBar
                float mfeR = (strategy.position_avg_price - ta.lowest(low, barsHeld + 1)) / risk0
                if barsHeld >= earlyBars and mfeR < earlyMfeR
                    strategy.close("S", comment="early_exit_mfe")
            if strategy.opentrades > 0 and bar_index - strategy.opentrades.entry_bar_index(0) >= maxHold
                strategy.close("S", comment="timeout")

if strategy.position_size == 0 and strategy.position_size[1] != 0
    activeStop := na
    entryBar   := na

// ---------------------------------------------------------------------
// Visuals (display=pane で十字線追従の値表示を抑制)
// ---------------------------------------------------------------------
grpVz       = "表示オプション"
showLevels  = input.bool(true, "Entry / SL / TP の価格ライン表示", group=grpVz)
keepHistory = input.bool(true, "過去全シグナルのラベルを残す", group=grpVz,
     tooltip="OFF にすると最新シグナルだけ表示")
levelExtend = input.int(10, "ライン延長 (バー数)", minval=1, group=grpVz)

plotshape(sqzLong, title="Squeeze Long", style=shape.triangleup,
     location=location.belowbar, color=color.new(color.lime, 0),
     size=size.small, display=display.pane)
plotshape(capLong, title="Capitulation Long", style=shape.triangleup,
     location=location.belowbar, color=color.new(color.aqua, 0),
     size=size.small, display=display.pane)
plotshape(llShort, title="Long Liquidation Short", style=shape.triangledown,
     location=location.abovebar, color=color.new(color.red, 0),
     size=size.small, display=display.pane)

// シグナル発生時に Entry / SL / TP を価格ラインで描画
var line  entryLine = na
var line  slLine    = na
var line  tpLine    = na
var label sigLabel  = na

bool anySig = sqzLong or capLong or llShort
float sigStop = sqzLong ? sqzStop : (capLong ? capStop : (llShort ? llStop : na))
bool  sigIsLong = sqzLong or capLong
string sigName = sqzLong ? "SQZ ロング" : (capLong ? "CAP ロング" : (llShort ? "LL ショート" : ""))
color  sigColor = sqzLong ? color.lime : (capLong ? color.aqua : color.red)

if showLevels and anySig and not na(sigStop)
    float entryPrice = close       // 次バー始値で約定するが、視覚的には close (信号バー終値) を起点
    float riskNow    = sigIsLong ? (entryPrice - sigStop) : (sigStop - entryPrice)
    float tpPrice    = sigIsLong ? (entryPrice + rr * riskNow) : (entryPrice - rr * riskNow)

    // keepHistory が OFF の時だけ、前回のオブジェクトを削除する
    if not keepHistory
        if not na(entryLine)
            line.delete(entryLine)
        if not na(slLine)
            line.delete(slLine)
        if not na(tpLine)
            line.delete(tpLine)
        if not na(sigLabel)
            label.delete(sigLabel)

    entryLine := line.new(bar_index, entryPrice, bar_index + levelExtend, entryPrice,
         xloc=xloc.bar_index, color=color.new(sigColor, 0), width=2, style=line.style_solid)
    slLine    := line.new(bar_index, sigStop, bar_index + levelExtend, sigStop,
         xloc=xloc.bar_index, color=color.new(color.red, 0), width=2, style=line.style_dashed)
    tpLine    := line.new(bar_index, tpPrice, bar_index + levelExtend, tpPrice,
         xloc=xloc.bar_index, color=color.new(color.green, 0), width=2, style=line.style_dashed)

    string txt = sigName + "\nEntry ≈ " + str.tostring(entryPrice, format.mintick) +
         "\nSL: " + str.tostring(sigStop, format.mintick) +
         "\nTP: " + str.tostring(tpPrice, format.mintick) +
         "\nRisk: " + str.tostring(math.abs(riskNow), format.mintick)
    sigLabel := label.new(bar_index, sigIsLong ? low : high, txt, xloc=xloc.bar_index,
         style=sigIsLong ? label.style_label_up : label.style_label_down,
         color=color.new(sigColor, 0), textcolor=color.black, size=size.small)

// Pine v5 のオブジェクト上限 (max_labels_count=500, max_lines_count=500) を超えた場合は
// 古いオブジェクトから自動的に削除される (FIFO)。多くの通貨で 50-130 件程度なので余裕。

alertcondition(sqzLong, title="Sqz v2.1 Long",
     message="SQZ v2.1 long on {{ticker}} {{interval}} @ {{close}}")
alertcondition(capLong, title="Cap v2.1 Long",
     message="CAP v2.1 long on {{ticker}} {{interval}} @ {{close}}")
alertcondition(llShort, title="LL v2.1 Short",
     message="LL v2.1 short on {{ticker}} {{interval}} @ {{close}}")

// ---------------------------------------------------------------------
// Status table (top-right) — どの構造が現在 ON か可視化
// ---------------------------------------------------------------------
var table tbl = table.new(position.top_right, 2, 5,
     bgcolor=color.new(color.black, 80), border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(tbl, 0, 0, "Symbol", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 0, sym, text_color=color.yellow, text_size=size.tiny)
    table.cell(tbl, 0, 1, "Mode", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 1, autoMatrix ? "AUTO" : "MANUAL",
         text_color=autoMatrix ? color.lime : color.orange, text_size=size.tiny)
    table.cell(tbl, 0, 2, "① Sqz", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 2, useSqz ? "ON" : "off",
         text_color=useSqz ? color.lime : color.gray, text_size=size.tiny)
    table.cell(tbl, 0, 3, "② Cap", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 3, useCap ? "ON" : "off",
         text_color=useCap ? color.aqua : color.gray, text_size=size.tiny)
    table.cell(tbl, 0, 4, "③ LL ", text_color=color.white, text_size=size.tiny)
    table.cell(tbl, 1, 4, useLL ? "ON" : "off",
         text_color=useLL ? color.red : color.gray, text_size=size.tiny)
