//@version=5
// =====================================================================
// Synapse USDJPY M5 v2 Context Visual
// =====================================================================
// Purpose:
//   Visual confirmation script for the mechanically testable Synapse draft.
//   Use mainly on USDJPY 5-minute charts.
//
// Concept:
//   - Trade the turn from wave 2 into wave 3.
//   - Detect a confirmed pivot sequence:
//       Long:  L H L H L H
//       Short: H L H L H L
//   - Confirm with one diagonal trendline and two horizontal levels:
//       A = internal wave-2 return high/low
//       B = right-shoulder break level
//   - TP uses half of wave 1, not full N.
//   - v2_context requires at least one upper timeframe alignment and no direct opposition.
//
// Notes:
//   This is an approximation for TradingView visual checking. It does not fully
//   reproduce discretionary elements such as diagonal half-value, NV, channel
//   divergence, maximum-adjustment hierarchy, or visual 123 exhaustion.
// =====================================================================

strategy("Synapse USDJPY M5 v2 Context Visual",
     overlay=true,
     pyramiding=0,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     process_orders_on_close=false,
     calc_on_every_tick=false,
     max_bars_back=5000,
     max_lines_count=500,
     max_labels_count=500)

// =====================================================================
// Inputs
// =====================================================================
grpCore = "■ Synapse M5 v2 Context"
pivotWidth       = input.int(8, "Pivot confirmation width", minval=2, maxval=30, group=grpCore)
atrLen           = input.int(14, "ATR", minval=1, group=grpCore)
minSwingAtr      = input.float(1.6, "Minimum swing ATR", minval=0.2, step=0.1, group=grpCore)
minWave1Atr      = input.float(1.5, "Minimum wave1 ATR", minval=0.2, step=0.1, group=grpCore)
breakBufferAtr   = input.float(0.05, "Break buffer ATR", minval=0.0, step=0.01, group=grpCore)
stopBufferAtr    = input.float(0.20, "SL buffer ATR", minval=0.0, step=0.05, group=grpCore)
maxRetrace       = input.float(0.95, "Maximum retrace", minval=0.5, maxval=1.5, step=0.01, group=grpCore)
entryMode        = input.string("B_confirmed", "Entry mode", options=["B_confirmed", "A_early", "Both"], group=grpCore)
minScore         = input.float(8.0, "Minimum score", minval=1.0, step=0.5, group=grpCore)
normalScorePlus  = input.float(1.5, "Normal lot score buffer", minval=0.0, step=0.5, group=grpCore)
skipHoliday      = input.bool(true, "12月15日から1月10日を除外", group=grpCore)

grpContext = "■ 上位足フィルタ"
useContext = input.bool(true, "H1/H4 context filter", group=grpContext)
h1Tf       = input.timeframe("60", "H1 context", group=grpContext)
h4Tf       = input.timeframe("240", "H4 context", group=grpContext)
emaLen     = input.int(100, "EMA length", minval=10, group=grpContext)

grpExit = "■ Exit"
maxHoldBars = input.int(144, "Time exit bars", minval=10, group=grpExit)

grpVisual = "■ Visual"
showSignals      = input.bool(true, "Signal labels", group=grpVisual)
showLines        = input.bool(true, "A/B/diagonal lines", group=grpVisual)
showActiveLevels = input.bool(true, "Active Entry/SL/TP plots", group=grpVisual)
showPivots       = input.bool(false, "Pivot marks", group=grpVisual)
showTable        = input.bool(true, "Status table", group=grpVisual)
labelBarsRight   = input.int(10, "Label bars to right", minval=0, maxval=80, group=grpVisual)
labelAtrAway     = input.float(3.0, "Label distance ATR", minval=0.2, step=0.2, group=grpVisual)
labelSizeOpt     = input.string("small", "Label size", options=["tiny", "small", "normal"], group=grpVisual)
useDynamicAlerts = input.bool(false, "Use alert() with prices", group=grpVisual)

labelSize = labelSizeOpt == "tiny" ? size.tiny : labelSizeOpt == "normal" ? size.normal : size.small

// =====================================================================
// Helpers
// =====================================================================
fmt(float v) =>
    na(v) ? "N/A" : str.tostring(v, format.mintick)

fmtPct(float v) =>
    na(v) ? "N/A" : str.tostring(v * 100.0, "#.#") + "%"

lineValue(int x0, float y0, int x1, float y1, int xNow) =>
    int bars = math.max(x1 - x0, 1)
    float slope = (y1 - y0) / bars
    [y1 + slope * (xNow - x1), slope]

pushPivot(array<int> bars, array<float> prices, array<float> atrs, array<string> kinds, int pBar, float pPrice, float pAtr, string pKind, float minAtr) =>
    int sz = array.size(kinds)
    if sz == 0
        array.push(bars, pBar)
        array.push(prices, pPrice)
        array.push(atrs, pAtr)
        array.push(kinds, pKind)
    else
        string lastKind = array.get(kinds, sz - 1)
        float lastPrice = array.get(prices, sz - 1)
        float lastAtr = array.get(atrs, sz - 1)
        if pKind == lastKind
            bool moreExtreme = (pKind == "H" and pPrice > lastPrice) or (pKind == "L" and pPrice < lastPrice)
            if moreExtreme
                array.set(bars, sz - 1, pBar)
                array.set(prices, sz - 1, pPrice)
                array.set(atrs, sz - 1, pAtr)
        else
            float swing = math.abs(pPrice - lastPrice)
            float threshold = math.max(pAtr, lastAtr) * minAtr
            if swing >= threshold
                array.push(bars, pBar)
                array.push(prices, pPrice)
                array.push(atrs, pAtr)
                array.push(kinds, pKind)
    while array.size(kinds) > 12
        array.shift(bars)
        array.shift(prices)
        array.shift(atrs)
        array.shift(kinds)
    true

// =====================================================================
// Indicators and context
// =====================================================================
atr = ta.atr(atrLen)
barRange = math.max(high - low, syminfo.mintick)
bodyRatio = math.abs(close - open) / barRange
ema100 = ta.ema(close, emaLen)
emaSlopeBars = 288
emaSlope = ema100 - ema100[emaSlopeBars]

h1Close = request.security(syminfo.tickerid, h1Tf, close, barmerge.gaps_off, barmerge.lookahead_off)
h1Ema = request.security(syminfo.tickerid, h1Tf, ta.ema(close, emaLen), barmerge.gaps_off, barmerge.lookahead_off)
h1Slope = request.security(syminfo.tickerid, h1Tf, ta.ema(close, emaLen) - ta.ema(close, emaLen)[24], barmerge.gaps_off, barmerge.lookahead_off)

h4Close = request.security(syminfo.tickerid, h4Tf, close, barmerge.gaps_off, barmerge.lookahead_off)
h4Ema = request.security(syminfo.tickerid, h4Tf, ta.ema(close, emaLen), barmerge.gaps_off, barmerge.lookahead_off)
h4Slope = request.security(syminfo.tickerid, h4Tf, ta.ema(close, emaLen) - ta.ema(close, emaLen)[6], barmerge.gaps_off, barmerge.lookahead_off)

holiday = skipHoliday and ((month(time) == 12 and dayofmonth(time) >= 15) or (month(time) == 1 and dayofmonth(time) <= 10))

// =====================================================================
// Confirmed pivots
// =====================================================================
var array<int> pBars = array.new_int()
var array<float> pPrices = array.new_float()
var array<float> pAtrs = array.new_float()
var array<string> pKinds = array.new_string()

ph = ta.pivothigh(high, pivotWidth, pivotWidth)
pl = ta.pivotlow(low, pivotWidth, pivotWidth)

if not na(ph) and na(pl) and not na(atr[pivotWidth])
    pushPivot(pBars, pPrices, pAtrs, pKinds, bar_index - pivotWidth, ph, atr[pivotWidth], "H", minSwingAtr)

if not na(pl) and na(ph) and not na(atr[pivotWidth])
    pushPivot(pBars, pPrices, pAtrs, pKinds, bar_index - pivotWidth, pl, atr[pivotWidth], "L", minSwingAtr)

plotshape(showPivots and not na(ph), title="Pivot H", style=shape.circle, location=location.abovebar, offset=-pivotWidth, color=color.new(color.red, 0), size=size.tiny)
plotshape(showPivots and not na(pl), title="Pivot L", style=shape.circle, location=location.belowbar, offset=-pivotWidth, color=color.new(color.lime, 0), size=size.tiny)

// =====================================================================
// Signal state
// =====================================================================
bool longSignal = false
bool shortSignal = false
string sigMode = ""
string lotText = ""
string reasonText = ""
float sigScore = na
float sigEntryEst = na
float sigStop = na
float sigTarget = na
float sigA = na
float sigB = na
float sigTrendline = na
float sigRetrace = na
float sigPlannedRr = na
int sigP0Bar = na
int sigP1Bar = na
float sigP0Price = na
float sigP1Price = na

if array.size(pKinds) >= 6 and not holiday and strategy.position_size == 0 and not na(atr)
    int sz = array.size(pKinds)
    string k0 = array.get(pKinds, sz - 6)
    string k1 = array.get(pKinds, sz - 5)
    string k2 = array.get(pKinds, sz - 4)
    string k3 = array.get(pKinds, sz - 3)
    string k4 = array.get(pKinds, sz - 2)
    string k5 = array.get(pKinds, sz - 1)
    string pattern = k0 + k1 + k2 + k3 + k4 + k5

    int b0 = array.get(pBars, sz - 6)
    int b1 = array.get(pBars, sz - 5)
    int b2 = array.get(pBars, sz - 4)
    int b3 = array.get(pBars, sz - 3)
    int b4 = array.get(pBars, sz - 2)
    int b5 = array.get(pBars, sz - 1)
    float y0 = array.get(pPrices, sz - 6)
    float y1 = array.get(pPrices, sz - 5)
    float y2 = array.get(pPrices, sz - 4)
    float y3 = array.get(pPrices, sz - 3)
    float y4 = array.get(pPrices, sz - 2)
    float y5 = array.get(pPrices, sz - 1)

    float buffer = atr * breakBufferAtr

    if pattern == "LHLHLH"
        float wave1 = y1 - y0
        if wave1 > atr * minWave1Atr
            [tlNow, tlSlope] = lineValue(b1, y1, b3, y3, bar_index)
            bool lineBreak = close > tlNow + buffer and close[1] <= tlNow + atr * 0.20
            bool aBreak = close > y3 + buffer
            bool bBreak = close > y5 + buffer and close[1] <= y5 + buffer
            bool triggerOk = entryMode == "B_confirmed" ? bBreak : entryMode == "A_early" ? (lineBreak and aBreak) : (bBreak or (lineBreak and aBreak))
            float retrace = (y1 - y4) / wave1
            int wave1Bars = math.max(b1 - b0, 1)
            int adjustBars = math.max(b4 - b1, 1)
            bool retraceOk = (retrace >= 0.618 and retrace <= 0.886) or (retrace >= 0.50 and retrace < 0.618 and adjustBars >= wave1Bars)
            bool maxRetraceOk = retrace <= maxRetrace
            bool rightShoulderOk = y4 >= y2 - atr * 0.75
            float target = y4 + wave1 * 0.50
            float stop = y4 - atr * stopBufferAtr
            bool priceOk = close > stop and target > close
            bool h1Good = h1Close >= h1Ema and h1Slope >= 0
            bool h4Good = h4Close >= h4Ema and h4Slope >= 0
            bool h1Bad = h1Close < h1Ema and h1Slope < 0
            bool h4Bad = h4Close < h4Ema and h4Slope < 0
            int align = (h1Good ? 1 : 0) + (h4Good ? 1 : 0)
            int oppose = (h1Bad ? 1 : 0) + (h4Bad ? 1 : 0)
            bool contextOk = not useContext or (align >= 1 and oppose == 0)
            float score = 0.0
            score += lineBreak ? 2.0 : 0.0
            score += aBreak ? 2.0 : 0.0
            score += bBreak ? 2.0 : 0.0
            score += retrace >= 0.618 ? 2.5 : 1.2
            score += rightShoulderOk ? 1.0 : 0.0
            score += bodyRatio >= 0.40 ? 1.0 : 0.0
            score += emaSlope > 0 ? 0.5 : 0.0
            score += y5 > y3 ? 1.0 : 0.0
            score += math.min(2, align)
            score -= oppose
            if triggerOk and retraceOk and maxRetraceOk and rightShoulderOk and priceOk and contextOk and score >= minScore
                longSignal := true
                sigMode := bBreak ? "B_confirmed" : "A_early"
                sigScore := score
                lotText := score >= minScore + normalScorePlus ? "通常ロット" : "半ロット"
                reasonText := "斜め:" + (lineBreak ? "OK" : "-") + " A:" + (aBreak ? "OK" : "-") + " B:" + (bBreak ? "OK" : "-") + " 上位:" + str.tostring(align) + "順"
                sigEntryEst := close
                sigStop := stop
                sigTarget := target
                sigA := y3
                sigB := y5
                sigTrendline := tlNow
                sigRetrace := retrace
                sigPlannedRr := (target - close) / math.max(close - stop, syminfo.mintick)
                sigP0Bar := b1
                sigP0Price := y1
                sigP1Bar := b3
                sigP1Price := y3

    if pattern == "HLHLHL"
        float wave1 = y0 - y1
        if wave1 > atr * minWave1Atr
            [tlNow, tlSlope] = lineValue(b1, y1, b3, y3, bar_index)
            bool lineBreak = close < tlNow - buffer and close[1] >= tlNow - atr * 0.20
            bool aBreak = close < y3 - buffer
            bool bBreak = close < y5 - buffer and close[1] >= y5 - buffer
            bool triggerOk = entryMode == "B_confirmed" ? bBreak : entryMode == "A_early" ? (lineBreak and aBreak) : (bBreak or (lineBreak and aBreak))
            float retrace = (y4 - y1) / wave1
            int wave1Bars = math.max(b1 - b0, 1)
            int adjustBars = math.max(b4 - b1, 1)
            bool retraceOk = (retrace >= 0.618 and retrace <= 0.886) or (retrace >= 0.50 and retrace < 0.618 and adjustBars >= wave1Bars)
            bool maxRetraceOk = retrace <= maxRetrace
            bool rightShoulderOk = y4 <= y2 + atr * 0.75
            float target = y4 - wave1 * 0.50
            float stop = y4 + atr * stopBufferAtr
            bool priceOk = close < stop and target < close
            bool h1Good = h1Close <= h1Ema and h1Slope <= 0
            bool h4Good = h4Close <= h4Ema and h4Slope <= 0
            bool h1Bad = h1Close > h1Ema and h1Slope > 0
            bool h4Bad = h4Close > h4Ema and h4Slope > 0
            int align = (h1Good ? 1 : 0) + (h4Good ? 1 : 0)
            int oppose = (h1Bad ? 1 : 0) + (h4Bad ? 1 : 0)
            bool contextOk = not useContext or (align >= 1 and oppose == 0)
            float score = 0.0
            score += lineBreak ? 2.0 : 0.0
            score += aBreak ? 2.0 : 0.0
            score += bBreak ? 2.0 : 0.0
            score += retrace >= 0.618 ? 2.5 : 1.2
            score += rightShoulderOk ? 1.0 : 0.0
            score += bodyRatio >= 0.40 ? 1.0 : 0.0
            score += emaSlope < 0 ? 0.5 : 0.0
            score += y5 < y3 ? 1.0 : 0.0
            score += math.min(2, align)
            score -= oppose
            if triggerOk and retraceOk and maxRetraceOk and rightShoulderOk and priceOk and contextOk and score >= minScore
                shortSignal := true
                sigMode := bBreak ? "B_confirmed" : "A_early"
                sigScore := score
                lotText := score >= minScore + normalScorePlus ? "通常ロット" : "半ロット"
                reasonText := "斜め:" + (lineBreak ? "OK" : "-") + " A:" + (aBreak ? "OK" : "-") + " B:" + (bBreak ? "OK" : "-") + " 上位:" + str.tostring(align) + "順"
                sigEntryEst := close
                sigStop := stop
                sigTarget := target
                sigA := y3
                sigB := y5
                sigTrendline := tlNow
                sigRetrace := retrace
                sigPlannedRr := (close - target) / math.max(stop - close, syminfo.mintick)
                sigP0Bar := b1
                sigP0Price := y1
                sigP1Bar := b3
                sigP1Price := y3

// =====================================================================
// Orders and active level tracking
// =====================================================================
var float activeEntry = na
var float activeStop = na
var float activeTarget = na
var int activeEntryBar = na

if longSignal
    activeStop := sigStop
    activeTarget := sigTarget
    activeEntryBar := bar_index + 1
    strategy.entry("Synapse Long", strategy.long)

if shortSignal
    activeStop := sigStop
    activeTarget := sigTarget
    activeEntryBar := bar_index + 1
    strategy.entry("Synapse Short", strategy.short)

if strategy.position_size > 0 and not na(activeStop) and not na(activeTarget)
    activeEntry := strategy.position_avg_price
    strategy.exit("L Exit", from_entry="Synapse Long", stop=activeStop, limit=activeTarget)

if strategy.position_size < 0 and not na(activeStop) and not na(activeTarget)
    activeEntry := strategy.position_avg_price
    strategy.exit("S Exit", from_entry="Synapse Short", stop=activeStop, limit=activeTarget)

if strategy.position_size != 0 and not na(activeEntryBar) and bar_index - activeEntryBar >= maxHoldBars
    strategy.close_all(comment="Time exit")

if strategy.position_size == 0 and strategy.position_size[1] != 0
    activeEntry := na
    activeStop := na
    activeTarget := na
    activeEntryBar := na

// =====================================================================
// Visuals
// =====================================================================
plotshape(showSignals and longSignal, title="Long signal", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="Syn L")
plotshape(showSignals and shortSignal, title="Short signal", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="Syn S")

plot(showActiveLevels and strategy.position_size != 0 ? activeEntry : na, title="Active Entry", color=color.new(color.yellow, 0), linewidth=2, style=plot.style_linebr)
plot(showActiveLevels and strategy.position_size != 0 ? activeStop : na, title="Active SL", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(showActiveLevels and strategy.position_size != 0 ? activeTarget : na, title="Active Half TP", color=color.new(color.lime, 0), linewidth=2, style=plot.style_linebr)

if showLines and (longSignal or shortSignal)
    line.new(sigP0Bar, sigP0Price, bar_index, sigTrendline, color=color.new(color.aqua, 0), width=2)
    line.new(bar_index - 40, sigA, bar_index + 20, sigA, color=color.new(color.orange, 25), style=line.style_dashed)
    line.new(bar_index - 40, sigB, bar_index + 20, sigB, color=color.new(color.yellow, 0), style=line.style_dashed)
    line.new(bar_index, sigStop, bar_index + 30, sigStop, color=color.new(color.red, 0), width=2)
    line.new(bar_index, sigTarget, bar_index + 30, sigTarget, color=color.new(color.lime, 0), width=2)

if showSignals and (longSignal or shortSignal)
    bool isLong = longSignal
    int xLab = bar_index + labelBarsRight
    float yAnchor = isLong ? low : high
    float yLab = isLong ? low - atr * labelAtrAway : high + atr * labelAtrAway
    color bg = lotText == "通常ロット" ? color.new(color.yellow, 0) : color.new(color.silver, 0)
    color txtCol = color.black
    string title = isLong ? "LONG" : "SHORT"
    string msg = title + " " + sigMode + "\n" +
         lotText + " / score " + str.tostring(sigScore, "#.#") + "\n" +
         "Signal: " + fmt(sigEntryEst) + "\n" +
         "SL: " + fmt(sigStop) + "\n" +
         "Half TP: " + fmt(sigTarget) + "\n" +
         "RR: " + str.tostring(sigPlannedRr, "#.##") + "\n" +
         "Retrace: " + fmtPct(sigRetrace) + "\n" +
         reasonText
    line.new(bar_index, yAnchor, xLab, yLab, color=color.new(isLong ? color.lime : color.red, 0), width=1)
    label.new(xLab, yLab, msg, style=isLong ? label.style_label_up : label.style_label_down, color=bg, textcolor=txtCol, size=labelSize)

bgcolor(holiday ? color.new(color.gray, 88) : na, title="Holiday skip")

// =====================================================================
// Table
// =====================================================================
var table t = table.new(position.bottom_left, 2, 8, bgcolor=color.new(color.black, 82), border_color=color.new(color.gray, 20), border_width=1)
if showTable and barstate.islast
    table.cell(t, 0, 0, "TF", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 0, timeframe.period, text_color=color.yellow, text_size=size.tiny)
    table.cell(t, 0, 1, "Pivots", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 1, str.tostring(array.size(pKinds)), text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 2, "H1", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, h1Close >= h1Ema and h1Slope >= 0 ? "LONG" : h1Close <= h1Ema and h1Slope <= 0 ? "SHORT" : "FLAT", text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 3, "H4", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, h4Close >= h4Ema and h4Slope >= 0 ? "LONG" : h4Close <= h4Ema and h4Slope <= 0 ? "SHORT" : "FLAT", text_color=color.white, text_size=size.tiny)
    table.cell(t, 0, 4, "Last signal", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, longSignal ? "LONG" : shortSignal ? "SHORT" : "NONE", text_color=longSignal ? color.lime : shortSignal ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 0, 5, "Mode", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 5, sigMode == "" ? "N/A" : sigMode, text_color=color.aqua, text_size=size.tiny)
    table.cell(t, 0, 6, "Lot", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 6, lotText == "" ? "N/A" : lotText, text_color=color.yellow, text_size=size.tiny)
    table.cell(t, 0, 7, "Holiday", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 7, holiday ? "SKIP" : "OFF", text_color=holiday ? color.orange : color.lime, text_size=size.tiny)

// =====================================================================
// Alerts
// =====================================================================
alertcondition(longSignal, title="Synapse USDJPY M5 Long", message="Synapse USDJPY M5 LONG on {{ticker}} {{interval}} close={{close}}")
alertcondition(shortSignal, title="Synapse USDJPY M5 Short", message="Synapse USDJPY M5 SHORT on {{ticker}} {{interval}} close={{close}}")

if useDynamicAlerts and longSignal
    alert("Synapse LONG\nSymbol: " + syminfo.ticker + "\nSignal: " + fmt(sigEntryEst) + "\nSL: " + fmt(sigStop) + "\nHalf TP: " + fmt(sigTarget) + "\nLot: " + lotText, alert.freq_once_per_bar_close)

if useDynamicAlerts and shortSignal
    alert("Synapse SHORT\nSymbol: " + syminfo.ticker + "\nSignal: " + fmt(sigEntryEst) + "\nSL: " + fmt(sigStop) + "\nHalf TP: " + fmt(sigTarget) + "\nLot: " + lotText, alert.freq_once_per_bar_close)
